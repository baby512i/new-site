---
type AlertTone = "info" | "warning" | "danger" | "success";

interface Props {
  tone?: AlertTone;
  title?: string;
  class?: string;
  [key: string]: unknown;
}

const {
  tone = "info",
  title,
  class: className = "",
  ...rest
} = Astro.props;

const baseClass =
  "rounded-[var(--radius-lg)] border border-l-4 px-4 py-3 text-sm md:px-5 md:py-4";

const toneClasses: Record<AlertTone, string> = {
  info: "border-[var(--border-strong)] bg-[var(--card)] text-[var(--foreground)]",
  warning: "border-[var(--warning)] bg-[var(--card)] text-[var(--foreground)]",
  danger: "border-[var(--danger)] bg-[var(--card)] text-[var(--foreground)]",
  success: "border-[var(--success)] bg-[var(--card)] text-[var(--foreground)]",
};

const finalClass = [baseClass, toneClasses[tone], className].filter(Boolean).join(" ");
---

<div {...rest} class={finalClass} role="status" aria-live="polite">
  {title ? <p class="mb-1 font-semibold">{title}</p> : null}
  <div>
    <slot />
  </div>
</div>
