---
import type { CreateTokenPlatformConfig } from "../../../lib/tool-config/create-token-platforms";

interface Props {
  platform: CreateTokenPlatformConfig;
}

const { platform } = Astro.props;

const baseSteps = [
  {
    title: "Fill the form",
    description:
      "Enter token name, symbol, and any platform-specific fields. The form validates inline as you type. No wallet needed yet.",
  },
  {
    title: "Review",
    description:
      "Open the review panel to verify every value. The summary shows the platform, fees, and authority decisions in plain language.",
  },
  {
    title: "Connect & sign",
    description:
      "Click the action button to connect your Solana wallet and sign the unsigned transaction prepared by dxra-core-api.",
  },
  {
    title: "Confirm",
    description:
      "We submit the signed transaction and wait for confirmation. The mint address and explorer link appear once it confirms on-chain.",
  },
];

const platformSteps: Record<typeof platform.id, string> = {
  spl: "Standard SPL mint, metadata account, and holder account creation in a single signed transaction.",
  pumpfun:
    "Pump.fun creation call: the platform sets supply, decimals, and curve. Optional initial buy is bundled in the same flow.",
  raydiumLaunchlab:
    "LaunchLab creation call: launch parameters and metadata are sent in one transaction prepared by dxra-core-api.",
  meteoraDbc:
    "Meteora DBC creation call: bonding curve preset and metadata are sent together. Curve choice is final at launch.",
  taxToken:
    "Token-2022 mint with the transfer fee extension. Basis points, max fee, and authority configuration are set during creation.",
};
---

<section
  aria-labelledby="create-token-how-heading"
  class="grid gap-4 rounded-[var(--radius-2xl)] border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[var(--shadow-xs)] sm:p-6"
>
  <header>
    <h2
      id="create-token-how-heading"
      class="text-lg font-semibold tracking-[var(--tracking-heading)] text-[var(--color-text)] sm:text-xl"
    >
      How it works
    </h2>
    <p class="mt-1 text-sm leading-[var(--leading-body)] text-[var(--color-text-muted)]">
      {platformSteps[platform.id]}
    </p>
  </header>

  <ol class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
    {
      baseSteps.map((step, index) => (
        <li class="flex h-full flex-col gap-2 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-muted)] p-4">
          <span class="inline-flex h-7 w-7 items-center justify-center rounded-full border border-[var(--color-brand-border)] bg-[var(--color-brand-soft)] text-xs font-semibold text-[var(--color-brand-text)]">
            {index + 1}
          </span>
          <p class="text-sm font-semibold text-[var(--color-text)]">{step.title}</p>
          <p class="text-sm leading-[var(--leading-body)] text-[var(--color-text-muted)]">
            {step.description}
          </p>
        </li>
      ))
    }
  </ol>
</section>
