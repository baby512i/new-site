---
import {
  listCreateTokenPlatforms,
  type CreateTokenPlatform,
} from "../../../lib/tool-config/create-token-platforms";
import PumpFunIcon from "../../icons/PumpFunIcon.astro";
import RaydiumLaunchlabIcon from "../../icons/RaydiumLaunchlabIcon.astro";
import MeteoraIcon from "../../icons/MeteoraIcon.astro";

interface Props {
  activePlatformId: CreateTokenPlatform;
  isUmbrella?: boolean;
}

const { activePlatformId, isUmbrella = false } = Astro.props;
const platforms = listCreateTokenPlatforms();

const navLabels: Record<CreateTokenPlatform, string> = {
  spl: "SPL Token",
  taxToken: "Tax Token",
  pumpfun: "Pump Fun",
  raydiumLaunchlab: "LaunchLab",
  meteoraDbc: "Meteora DBC",
};
---

<section
  aria-labelledby="create-token-platform-nav-heading"
  class="create-token-type-nav grid gap-4 rounded-[var(--radius-xl)] border border-[var(--color-border)] bg-[var(--color-surface-muted)] p-4 sm:p-5"
>
  <h2
    id="create-token-platform-nav-heading"
    class="text-base font-semibold tracking-[var(--tracking-heading)] text-[var(--color-text)] sm:text-lg"
  >
    Select Token Type
  </h2>

  <nav aria-label="Token types">
    <ul class="create-token-type-nav__list">
      {
        platforms.map((platform) => {
          const active = !isUmbrella && platform.id === activePlatformId;
          return (
            <li class="create-token-type-nav__item">
              <a
                href={platform.url}
                aria-current={active ? "page" : undefined}
                class:list={[
                  "create-token-type-option",
                  active && "create-token-type-option--active",
                ]}
              >
                <span class="create-token-type-radio" aria-hidden="true">
                  <span class="create-token-type-radio__dot" />
                </span>

                {platform.id === "pumpfun" ? (
                  <PumpFunIcon class="h-4 w-4 shrink-0" />
                ) : null}
                {platform.id === "raydiumLaunchlab" ? (
                  <RaydiumLaunchlabIcon class="h-4 w-4 shrink-0" />
                ) : null}
                {platform.id === "meteoraDbc" ? (
                  <MeteoraIcon class="h-4 w-4 shrink-0" />
                ) : null}

                <span class="text-sm font-medium text-[var(--color-text)]">
                  {navLabels[platform.id]}
                </span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</section>

<style>
  .create-token-type-nav__list {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 1.5rem;
    margin: 0 -0.25rem;
    padding: 0 0.25rem 0.25rem;
    overflow-x: auto;
    list-style: none;
  }

  .create-token-type-nav__item {
    flex: 0 0 auto;
  }

  @media (min-width: 640px) {
    .create-token-type-nav__list {
      flex-wrap: wrap;
      overflow-x: visible;
    }
  }
</style>
