---
import { Coins, Receipt, Wallet } from "@lucide/astro";
import type { CreateTokenPlatformConfig } from "../../../lib/tool-config/create-token-platforms";

interface Props {
  platform: CreateTokenPlatformConfig;
}

const { platform } = Astro.props;

const items = [
  {
    title: "Solana network rent",
    description:
      "Solana charges rent to create the mint, the metadata account, and your initial holder account. The amount depends on the token program and any extensions used.",
    icon: Coins,
  },
  {
    title: "Platform fee",
    description:
      `${platform.label} ${platform.id === "spl" || platform.id === "taxToken" ? "includes a small platform fee on top of network rent." : "charges its own creation fee in addition to Solana rent."} The exact amount is shown in the review panel before you sign.`,
    icon: Receipt,
  },
  {
    title: "Wallet gas only",
    description:
      "We never hold your SOL. The wallet you connect pays the rent and any platform fee directly to the network and the platform.",
    icon: Wallet,
  },
];
---

<section
  aria-labelledby="create-token-fees-heading"
  class="grid gap-4 rounded-[var(--radius-2xl)] border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[var(--shadow-xs)] sm:p-6"
>
  <header>
    <h2
      id="create-token-fees-heading"
      class="text-lg font-semibold tracking-[var(--tracking-heading)] text-[var(--color-text)] sm:text-xl"
    >
      How fees work
    </h2>
    <p class="mt-1 text-sm leading-[var(--leading-body)] text-[var(--color-text-muted)]">
      {platform.feeSummary}
    </p>
  </header>

  <ul class="grid gap-3 sm:grid-cols-3">
    {
      items.map((item) => {
        const Icon = item.icon;
        return (
          <li class="flex h-full flex-col gap-2 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-muted)] p-4">
            <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-[var(--radius-md)] border border-[var(--color-brand-border)] bg-[var(--color-brand-soft)] text-[var(--color-brand-text)]">
              <Icon class="h-4 w-4" aria-hidden="true" />
            </span>
            <p class="text-sm font-semibold text-[var(--color-text)]">{item.title}</p>
            <p class="text-sm leading-[var(--leading-body)] text-[var(--color-text-muted)]">
              {item.description}
            </p>
          </li>
        );
      })
    }
  </ul>
</section>
