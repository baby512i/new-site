---
import { TriangleAlert } from "@lucide/astro";
import Alert from "../../ui/Alert.astro";
import type { CreateTokenPlatformConfig } from "../../../lib/tool-config/create-token-platforms";

interface Props {
  platform: CreateTokenPlatformConfig;
}

const { platform } = Astro.props;
---

<section
  aria-labelledby="create-token-safety-heading"
  class="grid gap-4 rounded-[var(--radius-2xl)] border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[var(--shadow-xs)] sm:p-6"
>
  <header>
    <h2
      id="create-token-safety-heading"
      class="text-lg font-semibold tracking-[var(--tracking-heading)] text-[var(--color-text)] sm:text-xl"
    >
      Safety notes for {platform.shortLabel}
    </h2>
    <p class="mt-1 text-sm leading-[var(--leading-body)] text-[var(--color-text-muted)]">
      Read these before signing. Token creation actions are irreversible.
    </p>
  </header>

  <Alert tone="warning" title="Verify everything before signing">
    <ul class="grid gap-2">
      {
        platform.risks.map((risk) => (
          <li class="flex items-start gap-2 text-sm leading-[var(--leading-body)]">
            <span class="mt-0.5 inline-flex h-4 w-4 shrink-0 items-center justify-center text-[var(--color-warning-text)]">
              <TriangleAlert class="h-4 w-4" aria-hidden="true" />
            </span>
            <span>{risk}</span>
          </li>
        ))
      }
    </ul>
  </Alert>

  <p class="text-sm leading-[var(--leading-body)] text-[var(--color-text-muted)]">
    We never custody funds. Your wallet signs and submits its own transactions. The mint address shown after launch is the only on-chain identifier — share it carefully and avoid lookalikes.
  </p>
</section>
