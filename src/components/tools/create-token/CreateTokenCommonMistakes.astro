---
import { CircleX } from "@lucide/astro";
import type { CreateTokenPlatformConfig } from "../../../lib/tool-config/create-token-platforms";

interface Props {
  platform: CreateTokenPlatformConfig;
}

const { platform } = Astro.props;

interface Mistake {
  title: string;
  description: string;
}

const sharedMistakes: Mistake[] = [
  {
    title: "Wrong network",
    description:
      "Switching wallet to devnet by accident is the most common cause of confusion. Always verify the active network in the header before signing.",
  },
  {
    title: "Typos in name or symbol",
    description:
      "Once metadata is on-chain, fixing typos may require an update transaction or may not be possible at all if the metadata is immutable.",
  },
  {
    title: "Insufficient SOL for rent",
    description:
      "Transactions fail when the wallet does not have enough SOL for rent and platform fees. Keep a buffer beyond the displayed estimate.",
  },
];

const platformMistakes: Record<typeof platform.id, Mistake[]> = {
  spl: [
    {
      title: "Revoking authorities too early",
      description:
        "Once mint or freeze authority is revoked it cannot be restored. Decide deliberately and only after launch is stable.",
    },
    {
      title: "Picking the wrong decimals",
      description:
        "Decimals cannot be changed later. 6 or 9 are the most common values for fungible tokens.",
    },
  ],
  pumpfun: [
    {
      title: "Initial buy too large",
      description:
        "Initial buys execute on the bonding curve. A large buy moves price and can leave you holding tokens far above their fair entry.",
    },
    {
      title: "Using devnet by mistake",
      description:
        "Pump.fun is mainnet-first. Confirm your wallet is on the right cluster before signing.",
    },
  ],
  raydiumLaunchlab: [
    {
      title: "Skipping launch parameter review",
      description:
        "LaunchLab parameters are platform-defined. Review the launch summary carefully before signing.",
    },
    {
      title: "Missing migration awareness",
      description:
        "LaunchLab tokens migrate liquidity once thresholds are met. Understand the migration target before launch.",
    },
  ],
  meteoraDbc: [
    {
      title: "Choosing the wrong curve preset",
      description:
        "Curve presets define the entire pricing behaviour of the launch. Pick deliberately and read Meteora docs before signing.",
    },
    {
      title: "Not testing on devnet",
      description:
        "If Meteora DBC supports a devnet preset, test there first. Curve mistakes are expensive on mainnet.",
    },
  ],
  taxToken: [
    {
      title: "Setting a transfer fee too high",
      description:
        "Tax above ~5% is often filtered out by aggregators and discourages traders. Use small basis points unless you have a strong reason.",
    },
    {
      title: "Forgetting authority responsibilities",
      description:
        "If you keep transfer-fee authority, holders must trust you not to raise the fee. Communicate clearly or revoke it.",
    },
    {
      title: "Assuming full Token-2022 DEX support",
      description:
        "Token-2022 transfer-fee support varies across wallets, explorers, and DEXes. Verify your liquidity venue and aggregator before launching at scale.",
    },
  ],
};

const mistakes = [...sharedMistakes, ...platformMistakes[platform.id]];
---

<section
  aria-labelledby="create-token-mistakes-heading"
  class="grid gap-4 rounded-[var(--radius-2xl)] border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[var(--shadow-xs)] sm:p-6"
>
  <header>
    <h2
      id="create-token-mistakes-heading"
      class="text-lg font-semibold tracking-[var(--tracking-heading)] text-[var(--color-text)] sm:text-xl"
    >
      Common mistakes
    </h2>
    <p class="mt-1 text-sm leading-[var(--leading-body)] text-[var(--color-text-muted)]">
      Avoiding these saves you SOL, time, and reputation.
    </p>
  </header>

  <ul class="grid gap-3 sm:grid-cols-2">
    {
      mistakes.map((m) => (
        <li class="flex items-start gap-3 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-muted)] p-4">
          <span class="mt-0.5 inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-[var(--color-danger-border)] bg-[var(--color-danger-soft)] text-[var(--color-danger-text)]">
            <CircleX class="h-4 w-4" aria-hidden="true" />
          </span>
          <div>
            <p class="text-sm font-semibold text-[var(--color-text)]">{m.title}</p>
            <p class="mt-1 text-sm leading-[var(--leading-body)] text-[var(--color-text-muted)]">
              {m.description}
            </p>
          </div>
        </li>
      ))
    }
  </ul>
</section>
