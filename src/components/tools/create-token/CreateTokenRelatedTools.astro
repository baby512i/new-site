---
import { ArrowRight } from "@lucide/astro";
import type { CreateTokenPlatformConfig } from "../../../lib/tool-config/create-token-platforms";

interface Props {
  platform: CreateTokenPlatformConfig;
}

const { platform } = Astro.props;
---

<section
  aria-labelledby="create-token-related-heading"
  class="grid gap-4 rounded-[var(--radius-2xl)] border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[var(--shadow-xs)] sm:p-6"
>
  <header>
    <h2
      id="create-token-related-heading"
      class="text-lg font-semibold tracking-[var(--tracking-heading)] text-[var(--color-text)] sm:text-xl"
    >
      Related {platform.shortLabel} tools
    </h2>
    <p class="mt-1 text-sm leading-[var(--leading-body)] text-[var(--color-text-muted)]">
      Continue with the most common follow-up actions after launching.
    </p>
  </header>

  <ul class="grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
    {
      platform.relatedTools.map((tool) => (
        <li>
          <a
            href={tool.href}
            class="group flex h-full flex-col gap-2 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-muted)] p-4 transition-colors hover:border-[var(--color-brand-border)] hover:bg-[var(--color-brand-soft)]"
          >
            <p class="text-sm font-semibold text-[var(--color-text)] group-hover:text-[var(--color-brand-text)]">
              {tool.label}
            </p>
            <p class="text-sm leading-[var(--leading-body)] text-[var(--color-text-muted)]">
              {tool.description}
            </p>
            <span class="mt-auto inline-flex items-center gap-1.5 pt-1 text-sm font-semibold text-[var(--color-brand-text)]">
              Open
              <ArrowRight class="h-4 w-4" aria-hidden="true" />
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</section>
