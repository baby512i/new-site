---
import type { CreateTokenPlatformConfig } from "../../../lib/tool-config/create-token-platforms";

interface Props {
  platform: CreateTokenPlatformConfig;
}

const { platform } = Astro.props;

interface OnChainItem {
  title: string;
  description: string;
}

const itemsByPlatform: Record<typeof platform.id, OnChainItem[]> = {
  spl: [
    {
      title: "New SPL mint account",
      description:
        "A new mint account is created under the SPL Token Program. The mint stores supply, decimals, mint authority, and freeze authority.",
    },
    {
      title: "Metadata account",
      description:
        "An on-chain metadata account is created under the Token Metadata Program with your name, symbol, and metadata URI.",
    },
    {
      title: "Initial holder account",
      description:
        "Your wallet receives an associated token account holding the initial supply you configured.",
    },
    {
      title: "Optional authority changes",
      description:
        "If you enable revoke or immutable options, those changes are bundled in the same transaction and are permanent.",
    },
  ],
  pumpfun: [
    {
      title: "Pump.fun bonding curve account",
      description:
        "A bonding curve account is created and funded. Pump.fun controls the curve parameters; you control identity and metadata.",
    },
    {
      title: "Mint and metadata",
      description:
        "Pump.fun deploys a mint with platform-defined supply and decimals plus on-chain metadata using your name, ticker, and image URI.",
    },
    {
      title: "Optional initial buy",
      description:
        "If you set an initial buy, a swap is included that purchases tokens from the bonding curve in the same transaction.",
    },
  ],
  raydiumLaunchlab: [
    {
      title: "LaunchLab launch account",
      description:
        "A launch account is created under the Raydium LaunchLab program. It tracks state for the launch curve and migration.",
    },
    {
      title: "Mint and metadata",
      description:
        "A new mint is created with metadata using your name, ticker, and image. LaunchLab supplies the curve and migration logic.",
    },
    {
      title: "Optional initial buy",
      description:
        "If supported and configured, an initial buy from the launch curve is included in the same flow.",
    },
  ],
  meteoraDbc: [
    {
      title: "Meteora DBC pool / curve account",
      description:
        "A new bonding curve account is created with the preset you selected. Curve parameters are stored on-chain and enforced by the program.",
    },
    {
      title: "Mint and metadata",
      description:
        "A new mint is created with metadata using your name, ticker, and image URI.",
    },
    {
      title: "Migration setup",
      description:
        "DBC stores the migration target and conditions on-chain. Once thresholds are met, migration can be triggered.",
    },
  ],
  taxToken: [
    {
      title: "Token-2022 mint",
      description:
        "A new mint is created under the Token-2022 program. The transfer fee extension is initialised on this mint.",
    },
    {
      title: "Transfer fee configuration",
      description:
        "Basis points and max fee are written to the mint extension. They apply to every future transfer of this token.",
    },
    {
      title: "Authority assignments",
      description:
        "Transfer-fee authority and withdraw-withheld authority are written to the mint. These can be your wallet, another address, or revoked entirely.",
    },
    {
      title: "Initial holder account",
      description:
        "Your wallet receives a Token-2022 associated token account with the initial supply.",
    },
  ],
};

const items = itemsByPlatform[platform.id];
---

<section
  aria-labelledby="create-token-onchain-heading"
  class="grid gap-4 rounded-[var(--radius-2xl)] border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[var(--shadow-xs)] sm:p-6"
>
  <header>
    <h2
      id="create-token-onchain-heading"
      class="text-lg font-semibold tracking-[var(--tracking-heading)] text-[var(--color-text)] sm:text-xl"
    >
      What changes on-chain
    </h2>
    <p class="mt-1 text-sm leading-[var(--leading-body)] text-[var(--color-text-muted)]">
      Everything below is part of the transaction your wallet signs. Nothing happens before you confirm in your wallet.
    </p>
  </header>

  <div class="grid gap-3 sm:grid-cols-2">
    {
      items.map((item) => (
        <article class="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-muted)] p-4">
          <h3 class="text-sm font-semibold text-[var(--color-text)]">{item.title}</h3>
          <p class="mt-1 text-sm leading-[var(--leading-body)] text-[var(--color-text-muted)]">
            {item.description}
          </p>
        </article>
      ))
    }
  </div>
</section>
