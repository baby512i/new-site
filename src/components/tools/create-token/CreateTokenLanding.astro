---
import { ChevronRight } from "@lucide/astro";
import {
  CREATE_TOKEN_PLATFORMS,
  DEFAULT_CREATE_TOKEN_PLATFORM,
  type CreateTokenPlatform,
} from "../../../lib/tool-config/create-token-platforms";
import CreateTokenHero from "./CreateTokenHero.astro";
import CreateTokenPlatformNav from "./CreateTokenPlatformNav.astro";
import CreateTokenRequirements from "./CreateTokenRequirements.astro";
import CreateTokenFeeExplanation from "./CreateTokenFeeExplanation.astro";
import CreateTokenHowItWorks from "./CreateTokenHowItWorks.astro";
import CreateTokenOnChainChanges from "./CreateTokenOnChainChanges.astro";
import CreateTokenSafetyNotes from "./CreateTokenSafetyNotes.astro";
import CreateTokenCommonMistakes from "./CreateTokenCommonMistakes.astro";
import CreateTokenFaq from "./CreateTokenFaq.astro";
import CreateTokenRelatedTools from "./CreateTokenRelatedTools.astro";
import CreateTokenForm from "../../../islands/forms/create-token/CreateTokenForm.tsx";

interface Props {
  /**
   * Platform that owns the page. The umbrella `/create-solana-token` page
   * uses the default platform but renders the selector in "umbrella" mode so
   * no card is highlighted.
   */
  platformId?: CreateTokenPlatform;
  isUmbrella?: boolean;
}

const { platformId = DEFAULT_CREATE_TOKEN_PLATFORM, isUmbrella = false } =
  Astro.props;

const platform = CREATE_TOKEN_PLATFORMS[platformId];
---

<div class="grid gap-6 pb-6 lg:gap-8">
  <nav
    aria-label="Breadcrumb"
    class="flex flex-wrap items-center gap-1.5 text-xs text-[var(--color-text-muted)]"
  >
    <a
      href="/"
      class="rounded-[var(--radius-sm)] px-1 py-0.5 hover:text-[var(--color-brand-text)]"
    >
      Home
    </a>
    <ChevronRight class="h-3.5 w-3.5" aria-hidden="true" />
    <a
      href="/create-solana-token"
      class="rounded-[var(--radius-sm)] px-1 py-0.5 hover:text-[var(--color-brand-text)]"
    >
      Create Solana Token
    </a>
    {
      !isUmbrella ? (
        <>
          <ChevronRight class="h-3.5 w-3.5" aria-hidden="true" />
          <span class="rounded-[var(--radius-sm)] px-1 py-0.5 font-semibold text-[var(--color-text-secondary)]">
            {platform.shortLabel}
          </span>
        </>
      ) : null
    }
  </nav>

  <CreateTokenHero platform={platform} isUmbrella={isUmbrella} />

  <CreateTokenPlatformNav
    activePlatformId={platformId}
    isUmbrella={isUmbrella}
  />

  <section aria-label="Token creation form">
    <CreateTokenForm
      client:visible
      initialPlatform={platformId}
    />
  </section>

  <CreateTokenRequirements platform={platform} />
  <CreateTokenFeeExplanation platform={platform} />
  <CreateTokenHowItWorks platform={platform} />
  <CreateTokenOnChainChanges platform={platform} />
  <CreateTokenSafetyNotes platform={platform} />
  <CreateTokenCommonMistakes platform={platform} />
  <CreateTokenFaq platform={platform} />
  <CreateTokenRelatedTools platform={platform} />
</div>
