---
import { ChevronDown } from "@lucide/astro";
import type { CreateTokenPlatformConfig } from "../../../lib/tool-config/create-token-platforms";

interface Props {
  platform: CreateTokenPlatformConfig;
}

const { platform } = Astro.props;
---

<section
  aria-labelledby="create-token-faq-heading"
  class="grid gap-4 rounded-[var(--radius-2xl)] border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[var(--shadow-xs)] sm:p-6"
>
  <header>
    <h2
      id="create-token-faq-heading"
      class="text-lg font-semibold tracking-[var(--tracking-heading)] text-[var(--color-text)] sm:text-xl"
    >
      {platform.shortLabel} token creation FAQ
    </h2>
    <p class="mt-1 text-sm leading-[var(--leading-body)] text-[var(--color-text-muted)]">
      The most common questions for {platform.label.toLowerCase()} launches.
    </p>
  </header>

  <ul class="grid gap-2.5">
    {
      platform.faq.map((item, index) => (
        <li>
          <details class="group rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-muted)] open:border-[var(--color-brand-border)] open:bg-[var(--color-brand-soft)]">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-3 px-4 py-3 text-sm font-semibold text-[var(--color-text)]">
              <span>
                <span class="mr-2 inline-flex h-6 w-6 items-center justify-center rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] text-xs font-semibold text-[var(--color-text-muted)] group-open:border-[var(--color-brand-border)] group-open:bg-[var(--color-brand-soft)] group-open:text-[var(--color-brand-text)]">
                  {index + 1}
                </span>
                {item.q}
              </span>
              <ChevronDown
                class="h-4 w-4 shrink-0 text-[var(--color-text-muted)] transition-transform group-open:rotate-180"
                aria-hidden="true"
              />
            </summary>
            <div class="border-t border-[var(--color-border)] px-4 py-3 text-sm leading-[var(--leading-body)] text-[var(--color-text-secondary)]">
              {item.a}
            </div>
          </details>
        </li>
      ))
    }
  </ul>
</section>
