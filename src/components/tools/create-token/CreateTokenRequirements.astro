---
import { CircleCheck } from "@lucide/astro";
import type { CreateTokenPlatformConfig } from "../../../lib/tool-config/create-token-platforms";

interface Props {
  platform: CreateTokenPlatformConfig;
}

const { platform } = Astro.props;
---

<section
  aria-labelledby="create-token-requirements-heading"
  class="grid gap-4 rounded-[var(--radius-2xl)] border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[var(--shadow-xs)] sm:p-6"
>
  <header>
    <h2
      id="create-token-requirements-heading"
      class="text-lg font-semibold tracking-[var(--tracking-heading)] text-[var(--color-text)] sm:text-xl"
    >
      Requirements before you create
    </h2>
    <p class="mt-1 text-sm leading-[var(--leading-body)] text-[var(--color-text-muted)]">
      Prepare these before clicking the action button. The form is fillable without a wallet, but signing requires connection.
    </p>
  </header>

  <ul class="grid gap-2.5">
    {
      platform.requirements.map((line) => (
        <li class="flex items-start gap-2.5 text-sm leading-[var(--leading-body)] text-[var(--color-text-secondary)]">
          <span class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full border border-[var(--color-success-border)] bg-[var(--color-success-soft)] text-[var(--color-success-text)]">
            <CircleCheck class="h-3.5 w-3.5" aria-hidden="true" />
          </span>
          <span>{line}</span>
        </li>
      ))
    }
  </ul>
</section>
