---
import { Wallet, X } from "@lucide/astro";
import Button from "../../ui/Button.astro";
import DialogShell from "../../ui/DialogShell.astro";
---

<DialogShell id="header-pro-dialog" labelledBy="header-pro-title" widthClass="w-[min(40rem,calc(100vw-1rem))]">
  <div class="space-y-4 p-5 sm:space-y-5 sm:p-6">
    <div class="mx-auto h-1 w-12 rounded-full bg-[var(--color-text-muted)]/40 sm:hidden"></div>
    <div class="dialog-header flex items-start justify-between gap-3 pb-3.5 sm:pb-4">
      <div>
        <h2 id="header-pro-title" class="dialog-title">Become PRO</h2>
        <p class="dialog-description">PRO unlocks premium SOL tools.</p>
      </div>
      <button
        id="header-pro-close"
        type="button"
        class="dialog-close-button focus:outline-none"
        aria-label="Close PRO plans"
      >
        <X class="h-4 w-4" aria-hidden="true" />
      </button>
    </div>

    <fieldset class="space-y-2.5 border-0 p-0">
      <legend class="sr-only">Select a PRO plan</legend>

      <label class="pro-plan-card group flex min-h-14 cursor-pointer items-center gap-3 rounded-[var(--radius-xl)] border border-[var(--color-border)] bg-transparent px-4 py-3.5 has-[:focus-visible]:ring-2 has-[:focus-visible]:ring-[var(--color-pro-ring)] group-has-[:checked]:border-[var(--color-pro-border)] group-has-[:checked]:bg-[var(--color-pro-soft)]">
        <input type="radio" name="header-pro-plan" value="degen" checked class="peer sr-only" />
        <span
          aria-hidden="true"
          class="flex h-[18px] w-[18px] shrink-0 items-center justify-center rounded-full border border-[var(--color-text-muted)] bg-[var(--color-surface)] peer-checked:border-[var(--color-pro-border)]"
        >
          <span class="h-2 w-2 rounded-full bg-[var(--color-pro-text)] opacity-0 group-has-[:checked]:opacity-100"></span>
        </span>
        <span class="min-w-0 flex-1">
          <!-- Intentional 15px/13px: plan rows are compact dialog list rows with dense helper text. -->
          <span class="block text-[15px] font-semibold leading-tight text-[var(--color-text)]">Degen Pass</span>
          <span class="mt-1 block text-[13px] leading-4 text-[var(--color-text-muted)]">1 day access</span>
        </span>
        <span class="text-[15px] font-semibold text-[var(--color-text)] group-has-[:checked]:text-[var(--color-pro-text)]">5 SOL</span>
      </label>

      <label class="pro-plan-card group flex min-h-14 cursor-pointer items-center gap-3 rounded-[var(--radius-xl)] border border-[var(--color-border)] bg-transparent px-4 py-3.5 has-[:focus-visible]:ring-2 has-[:focus-visible]:ring-[var(--color-pro-ring)] group-has-[:checked]:border-[var(--color-pro-border)] group-has-[:checked]:bg-[var(--color-pro-soft)]">
        <input type="radio" name="header-pro-plan" value="trenches" class="peer sr-only" />
        <span
          aria-hidden="true"
          class="flex h-[18px] w-[18px] shrink-0 items-center justify-center rounded-full border border-[var(--color-text-muted)] bg-[var(--color-surface)] peer-checked:border-[var(--color-pro-border)]"
        >
          <span class="h-2 w-2 rounded-full bg-[var(--color-pro-text)] opacity-0 group-has-[:checked]:opacity-100"></span>
        </span>
        <span class="min-w-0 flex-1">
          <!-- Intentional 15px/13px: plan rows are compact dialog list rows with dense helper text. -->
          <span class="block text-[15px] font-semibold leading-tight text-[var(--color-text)]">Trenches Pass</span>
          <span class="mt-1 block text-[13px] leading-4 text-[var(--color-text-muted)]">1 month access</span>
        </span>
        <span class="text-[15px] font-semibold text-[var(--color-text)] group-has-[:checked]:text-[var(--color-pro-text)]">20 SOL</span>
      </label>

      <label class="pro-plan-card group flex min-h-14 cursor-pointer items-center gap-3 rounded-[var(--radius-xl)] border border-[var(--color-border)] bg-transparent px-4 py-3.5 has-[:focus-visible]:ring-2 has-[:focus-visible]:ring-[var(--color-pro-ring)] group-has-[:checked]:border-[var(--color-pro-border)] group-has-[:checked]:bg-[var(--color-pro-soft)]">
        <input type="radio" name="header-pro-plan" value="based" class="peer sr-only" />
        <span
          aria-hidden="true"
          class="flex h-[18px] w-[18px] shrink-0 items-center justify-center rounded-full border border-[var(--color-text-muted)] bg-[var(--color-surface)] peer-checked:border-[var(--color-pro-border)]"
        >
          <span class="h-2 w-2 rounded-full bg-[var(--color-pro-text)] opacity-0 group-has-[:checked]:opacity-100"></span>
        </span>
        <span class="min-w-0 flex-1">
          <!-- Intentional 15px/13px: plan rows are compact dialog list rows with dense helper text. -->
          <span class="block text-[15px] font-semibold leading-tight text-[var(--color-text)]">Based Pass</span>
          <span class="mt-1 block text-[13px] leading-4 text-[var(--color-text-muted)]">1 year access</span>
        </span>
        <span class="text-[15px] font-semibold text-[var(--color-text)] group-has-[:checked]:text-[var(--color-pro-text)]">75 SOL</span>
      </label>
    </fieldset>

    <Button
      id="header-pro-connect-wallet"
      fullWidth
      variant="primary"
      class="h-[2.95rem] rounded-[var(--radius-xl)] text-sm font-semibold"
    >
      <Wallet class="h-4 w-4" aria-hidden="true" />
      Connect Wallet to Continue
    </Button>

    <p class="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-muted)] px-3.5 py-2.5 text-xs leading-5 text-[var(--color-text-muted)]">
      PRO does not include Solana network transaction fees.
    </p>
  </div>
</DialogShell>
