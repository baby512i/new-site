---
import { Check, ChevronDown, Circle, Moon, SlidersHorizontal, Sparkles, Sun, X, Zap } from "@lucide/astro";
import Button from "../../ui/Button.astro";
import DialogShell from "../../ui/DialogShell.astro";
---

<DialogShell id="mobile-header-settings-dialog" labelledBy="mobile-header-settings-title" widthClass="w-[min(34rem,calc(100vw-1rem))]">
  <div class="dialog-header px-5 pb-3.5 pt-3 sm:px-6 sm:pb-4">
    <div class="mx-auto mb-3 h-1 w-12 rounded-full bg-[var(--color-text-muted)]/40"></div>
    <div class="flex items-center justify-between gap-3">
      <h2 id="mobile-header-settings-title" class="dialog-title">Header Settings</h2>
      <button
        id="mobile-header-settings-close"
        type="button"
        class="dialog-close-button focus:outline-none"
        aria-label="Close header settings"
      >
        <X class="h-4 w-4" aria-hidden="true" />
      </button>
    </div>
  </div>

  <div class="space-y-0">
    <section class="space-y-3.5 border-b border-[var(--color-border)] px-5 py-[18px] sm:px-6 sm:py-5">
      <p class="text-sm font-medium text-[var(--color-text-secondary)]">Network</p>
      <div class="grid gap-2.5">
        <button
          id="mobile-network-mainnet"
          type="button"
          data-mobile-network-option="mainnet"
          data-selected="true"
          class="flex min-h-12 items-center gap-3 rounded-[var(--radius-xl)] border border-[var(--color-border)] bg-[var(--color-surface-muted)] px-4 text-left text-[15px] font-medium text-[var(--color-text)] hover:bg-[var(--color-nav-hover)]"
        >
          <!-- Intentional 15px: dialog/mobile row readability target. -->
          <span class="inline-flex h-4 w-4 items-center justify-center rounded-full border-2 border-[var(--color-network-mainnet-border)] bg-[var(--color-network-mainnet-soft)]">
            <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-network-mainnet)]"></span>
          </span>
          <span class="flex-1 text-left">Mainnet</span>
          <Check id="mobile-network-check-mainnet" class="h-5 w-5 text-[var(--color-brand-text)]" aria-hidden="true" />
          <Circle id="mobile-network-unchecked-mainnet" class="hidden h-5 w-5 text-[var(--color-text-muted)]" aria-hidden="true" />
        </button>
        <button
          id="mobile-network-devnet"
          type="button"
          data-mobile-network-option="devnet"
          data-selected="false"
          class="flex min-h-12 items-center gap-3 rounded-[var(--radius-xl)] border border-[var(--color-border)] bg-[var(--color-surface-muted)] px-4 text-left text-[15px] font-medium text-[var(--color-text)] hover:bg-[var(--color-nav-hover)]"
        >
          <!-- Intentional 15px: dialog/mobile row readability target. -->
          <Zap class="h-[18px] w-[18px] text-[var(--color-network-devnet)]" aria-hidden="true" />
          <span class="flex-1 text-left">Devnet</span>
          <Check id="mobile-network-check-devnet" class="hidden h-5 w-5 text-[var(--color-brand-text)]" aria-hidden="true" />
          <Circle id="mobile-network-unchecked-devnet" class="h-5 w-5 text-[var(--color-text-muted)]" aria-hidden="true" />
        </button>
      </div>
    </section>

    <section class="space-y-3.5 border-b border-[var(--color-border)] px-5 py-[18px] sm:px-6 sm:py-5">
      <p class="text-sm font-medium text-[var(--color-text-secondary)]">Fee Settings</p>
      <Button
        id="mobile-open-fees-button"
        type="button"
        variant="outline"
        fullWidth
        class="min-h-12 justify-between rounded-[var(--radius-xl)] border border-[var(--color-border)] bg-[var(--color-surface-muted)] px-4 text-[15px] font-medium text-[var(--color-text)] hover:bg-[var(--color-nav-hover)]"
      >
        <!-- Intentional 15px: dialog/mobile row readability target. -->
        <span class="inline-flex items-center gap-3">
          <SlidersHorizontal class="h-[18px] w-[18px] text-[var(--color-brand-text)]" aria-hidden="true" />
          Fee Details
        </span>
        <ChevronDown class="-rotate-90 h-4 w-4 text-[var(--color-text-muted)]" aria-hidden="true" />
      </Button>
      <Button
        id="mobile-open-pro-button"
        type="button"
        variant="outline"
        fullWidth
        class="min-h-12 justify-between rounded-[var(--radius-xl)] border border-[var(--color-border)] bg-[var(--color-surface-muted)] px-4 text-[15px] font-medium text-[var(--color-text)] hover:bg-[var(--color-nav-hover)]"
      >
        <!-- Intentional 15px: dialog/mobile row readability target. -->
        <span class="inline-flex items-center gap-3">
          <Sparkles class="h-[18px] w-[18px] text-[var(--color-pro-text)]" aria-hidden="true" />
          PRO Plans
        </span>
        <ChevronDown class="-rotate-90 h-4 w-4 text-[var(--color-text-muted)]" aria-hidden="true" />
      </Button>
    </section>

    <section class="px-5 py-[18px] sm:px-6 sm:py-5">
      <Button
        id="mobile-theme-toggle"
        type="button"
        variant="outline"
        fullWidth
        ariaLabel="Toggle color theme"
        class="min-h-12 justify-between rounded-[var(--radius-xl)] border border-[var(--color-border)] bg-[var(--color-surface-muted)] px-4 text-[15px] font-medium text-[var(--color-text)] hover:bg-[var(--color-nav-hover)]"
      >
        <!-- Intentional 15px: dialog/mobile row readability target. -->
        <span class="inline-flex items-center gap-3">
          <span id="mobile-theme-toggle-icon-dark" class="hidden" aria-hidden="true">
            <Sun class="h-[18px] w-[18px] text-[var(--color-brand-text)]" aria-hidden="true" />
          </span>
          <span id="mobile-theme-toggle-icon-light" aria-hidden="true">
            <Moon class="h-[18px] w-[18px] text-[var(--color-brand-text)]" aria-hidden="true" />
          </span>
          <span>Toggle Theme</span>
        </span>
        <ChevronDown class="-rotate-90 h-4 w-4 text-[var(--color-text-muted)]" aria-hidden="true" />
      </Button>
    </section>
  </div>
</DialogShell>
