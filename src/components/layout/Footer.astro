---
const linkClass =
  "text-sm text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-brand-text)] focus-visible:text-[var(--color-brand-text)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--ring)]";
const headingClass = "text-sm font-semibold text-[var(--color-text)]";
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-footer)]">
  <div class="mx-auto max-w-screen-2xl px-4 py-10 sm:px-6 lg:px-8 lg:py-12">
    <!-- TODO: Ensure all footer routes exist as SEO pages before production; remove or replace non-existent links. -->
    <div class="grid gap-8 sm:gap-9 lg:grid-cols-4 lg:gap-10">
      <section aria-labelledby="footer-brand-title" class="lg:pr-4">
        <h2 id="footer-brand-title" class="text-base font-semibold tracking-tight text-[var(--color-text)]">
          Solana Tools
        </h2>
        <p class="mt-3 text-sm leading-6 text-[var(--color-text-secondary)]">
          Lightweight Solana tools for creating tokens, managing authorities, liquidity actions, wallet utilities, and safer on-chain workflows.
        </p>
        <p class="mt-3 text-sm leading-6 text-[var(--color-text-muted)]">
          Non-custodial by design. Wallet signing happens only when you confirm an action.
        </p>
      </section>

      <nav aria-label="Token tools links">
        <h3 class={headingClass}>Token Tools</h3>
        <ul class="mt-3 grid gap-2.5">
          <li><a href="/create-solana-token" class={linkClass}>Create Solana Token</a></li>
          <li><a href="/mint-solana-token" class={linkClass}>Mint Solana Token</a></li>
          <li><a href="/burn-solana-token" class={linkClass}>Burn Solana Token</a></li>
          <li><a href="/update-token-metadata" class={linkClass}>Update Token Metadata</a></li>
          <li><a href="/snapshot-token-holders" class={linkClass}>Snapshot Token Holders</a></li>
        </ul>
      </nav>

      <nav aria-label="Authority and liquidity links">
        <h3 class={headingClass}>Authority &amp; Liquidity</h3>
        <ul class="mt-3 grid gap-2.5">
          <li><a href="/revoke-solana-authority" class={linkClass}>Revoke Solana Authority</a></li>
          <li><a href="/revoke-mint-authority" class={linkClass}>Revoke Mint Authority</a></li>
          <li><a href="/create-liquidity-pool" class={linkClass}>Create Liquidity Pool</a></li>
          <li><a href="/add-solana-liquidity" class={linkClass}>Add Solana Liquidity</a></li>
          <li><a href="/remove-solana-liquidity" class={linkClass}>Remove Solana Liquidity</a></li>
        </ul>
      </nav>

      <nav aria-label="Resources and legal links">
        <h3 class={headingClass}>Resources &amp; Legal</h3>
        <ul class="mt-3 grid gap-2.5">
          <li><a href="/solana-token-management" class={linkClass}>Solana Token Management</a></li>
          <li><a href="/solana-wallet-tools" class={linkClass}>Solana Wallet Tools</a></li>
          <li><a href="/safety" class={linkClass}>Safety</a></li>
          <li><a href="/privacy" class={linkClass}>Privacy</a></li>
          <li><a href="/terms" class={linkClass}>Terms</a></li>
          <li><a href="/risk-disclaimer" class={linkClass}>Risk Disclaimer</a></li>
        </ul>
      </nav>
    </div>
  </div>

  <div class="border-t border-[var(--color-border)]">
    <div
      class="mx-auto flex max-w-screen-2xl flex-col items-center justify-between gap-2 px-4 py-4 text-xs text-[var(--color-text-muted)] sm:px-6 lg:flex-row lg:px-8"
    >
      <p>© {new Date().getFullYear()} Solana Tools. All rights reserved.</p>
      <p>Built for non-custodial Solana workflows.</p>
    </div>
  </div>
</footer>
