---
import {
  BookOpen,
  Briefcase,
  House,
  ChevronDown,
  ChevronLeft,
  ChevronRight,
  Coins,
  Droplets,
  Percent,
  Shield,
  TrendingUp,
  WalletMinimal,
  Wrench,
} from "@lucide/astro";
import MeteoraIcon from "../icons/MeteoraIcon.astro";
import OrcaIcon from "../icons/OrcaIcon.astro";
import PumpFunIcon from "../icons/PumpFunIcon.astro";
import PumpSwapIcon from "../icons/PumpSwapIcon.astro";
import RaydiumLaunchlabIcon from "../icons/RaydiumLaunchlabIcon.astro";

const groups = [
  {
    title: "Token Management",
    icon: Coins,
    items: [
      { href: "/mint-solana-token", label: "Mint Solana Token" },
      { href: "/burn-solana-token", label: "Burn Solana Token" },
      { href: "/update-token-metadata", label: "Update Token Metadata" },
      { href: "/view-token-metadata", label: "View Token Metadata" },
      { href: "/snapshot-token-holders", label: "Snapshot Token Holders" },
      { href: "/solana-token-multisender", label: "Solana Token Multisender" },
      { href: "/freeze-account", label: "Freeze Account" },
      { href: "/unfreeze-account", label: "Unfreeze Account" },
    ],
  },
  {
    title: "Authority Management",
    icon: Shield,
    items: [
      { href: "/revoke-solana-authority", label: "Revoke Solana Authority" },
      { href: "/revoke-mint-authority", label: "Revoke Mint Authority" },
      { href: "/revoke-freeze-authority", label: "Revoke Freeze Authority" },
      { href: "/revoke-metadata-authority", label: "Revoke Metadata Authority" },
      { href: "/revoke-tax-config-authority", label: "Revoke Tax Config Authority" },
      { href: "/revoke-withdraw-authority", label: "Revoke Withdraw Authority" },
      { href: "/transfer-token-authority", label: "Transfer Token Authority" },
    ],
  },
  {
    title: "Tax Tools",
    icon: Percent,
    items: [
      { href: "/claim-tax-fee", label: "Claim Tax Fee" },
      { href: "/change-tax-setting", label: "Change Tax Setting" },
    ],
  },
  {
    title: "Manage Liquidity",
    icon: Droplets,
    items: [
      { href: "/add-solana-liquidity", label: "Add Solana Liquidity" },
      { href: "/remove-solana-liquidity", label: "Remove Solana Liquidity" },
      { href: "/burn-solana-liquidity", label: "Burn Solana Liquidity" },
    ],
  },
  {
    title: "Pump.fun Zone",
    icon: PumpFunIcon,
    items: [
      { href: "/pump-bundler", label: "Pump Bundler" },
      { href: "/pump-volume-bot", label: "Pump Volume Bot" },
      { href: "/pump-bundle-buy", label: "Pump Bundle Buy" },
      { href: "/pump-bundle-sell", label: "Pump Bundle Sell" },
    ],
  },
  {
    title: "Pumpswap Zone",
    icon: PumpSwapIcon,
    items: [
      { href: "/pumpswap-bundler", label: "Pumpswap Bundler" },
      { href: "/pumpswap-volume-bot", label: "Pumpswap Volume Bot" },
      { href: "/pumpswap-bundle-buy", label: "Pumpswap Bundle Buy" },
      { href: "/pumpswap-bundle-sell", label: "Pumpswap Bundle Sell" },
    ],
  },
  {
    title: "Meteora Zone",
    icon: MeteoraIcon,
    items: [
      { href: "/meteora-bundler", label: "Meteora Bundler" },
      { href: "/meteora-volume-bot", label: "Meteora Volume Bot" },
      { href: "/meteora-bundle-buy", label: "Meteora Bundle Buy" },
      { href: "/meteora-bundle-sell", label: "Meteora Bundle Sell" },
    ],
  },
  {
    title: "Orca Zone",
    icon: OrcaIcon,
    items: [
      { href: "/orca-bundler", label: "Orca Bundler" },
      { href: "/orca-volume-bot", label: "Orca Volume Bot" },
      { href: "/orca-bundle-buy", label: "Orca Bundle Buy" },
      { href: "/orca-bundle-sell", label: "Orca Bundle Sell" },
    ],
  },
  {
    title: "Launchlab Zone",
    icon: RaydiumLaunchlabIcon,
    items: [
      { href: "/launchlab-bundler", label: "Launchlab Bundler" },
      { href: "/launchlab-volume-bot", label: "Launchlab Volume Bot" },
      { href: "/launchlab-bundle-buy", label: "Launchlab Bundle Buy" },
      { href: "/launchlab-bundle-sell", label: "Launchlab Bundle Sell" },
    ],
  },
  {
    title: "Solana Utilities",
    icon: Wrench,
    items: [
      { href: "/claim-your-sol", label: "Claim Your SOL" },
      { href: "/wrap-and-unwrap-sol", label: "Wrap and Unwrap SOL" },
      { href: "/collect-tokens", label: "Collect Tokens" },
      { href: "/collect-sol", label: "Collect SOL" },
    ],
  },
  {
    title: "Wallet Management",
    icon: WalletMinimal,
    items: [
      { href: "/manage-solana-wallets", label: "Manage Solana Wallets" },
      { href: "/vanity-address-generator", label: "Vanity Address Generator" },
    ],
  },
];

const topLevelTools = [
  { href: "/create-solana-token", label: "Create Solana Token", icon: Coins },
  { href: "/create-liquidity-pool", label: "Create Liquidity Pool", icon: Droplets },
  { href: "/volume-bot", label: "Volume Bot", icon: TrendingUp },
  { href: "/solana-portfolio-tracker", label: "Portfolio Tracker", icon: Briefcase },
];

function normalizePath(path: string) {
  const p = path.replace(/\/$/, "") || "/";
  return p;
}

const currentPath = normalizePath(Astro.url.pathname);

function isActive(href: string) {
  return normalizePath(href) === currentPath;
}

const homeActive = isActive("/");
---

<div
  class="relative shrink-0"
  style="overflow: visible;"
>
  <button
    type="button"
    id="sidebar-backdrop"
    class="fixed inset-x-0 bottom-0 top-[var(--header-height)] z-30 hidden bg-slate-950/35 dark:bg-slate-950/55 lg:hidden"
    aria-label="Close sidebar"
  />

  <button
    type="button"
    id="sidebar-toggle"
    class="absolute z-30 hidden h-8 w-8 -translate-y-1/2 items-center justify-center rounded-r-[var(--radius-md)] rounded-l-none border border-[var(--border)] border-l-0 bg-[var(--card)] text-slate-600 hover:text-blue-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 lg:flex dark:text-slate-300 dark:hover:text-sky-300 dark:focus-visible:outline-sky-400"
    style="top: 7rem; right: -0.5rem;"
    aria-controls="app-sidebar"
    aria-expanded="true"
    aria-label="Collapse sidebar"
  >
    <span class="sidebar-toggle-icon-expanded" aria-hidden="true">
      <ChevronLeft size={18} />
    </span>
    <span class="sidebar-toggle-icon-collapsed hidden" aria-hidden="true">
      <ChevronRight size={18} />
    </span>
  </button>

  <aside
    id="app-sidebar"
    class="sidebar-root fixed bottom-0 left-0 top-[var(--header-height)] z-40 h-[calc(100dvh-var(--header-height))] w-[min(288px,calc(100vw-2rem))] shrink-0 -translate-x-full overflow-hidden border-r border-[var(--border-muted)] bg-white/95 transition-none lg:sticky lg:top-[var(--header-height)] lg:z-auto lg:block lg:h-[calc(100vh-var(--header-height))] lg:w-[288px] lg:translate-x-0 lg:bg-white/90 dark:border-slate-800 dark:bg-slate-950"
    aria-label="Sidebar"
  >
  <div class="flex h-full flex-col">
    <!-- Scrollable nav -->
    <nav class="sidebar-scroll min-h-0 flex-1 overflow-y-auto overflow-x-visible px-3 py-4" aria-label="Tool navigation">
      <!-- Primary tools -->
      <div class="mb-5">
        <ul class="grid gap-1.5">
          <li>
            <a
              href="/"
              title="Home"
              aria-current={homeActive ? "page" : undefined}
              class:list={[
                "sidebar-nav-link group flex h-10 items-center gap-2.5 rounded-[var(--radius-lg)] px-2.5 text-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 dark:focus-visible:outline-sky-400",
                homeActive
                  ? "border border-blue-200 bg-blue-50/85 font-semibold text-blue-700 dark:border-sky-500/45 dark:bg-sky-400/12 dark:text-sky-200"
                  : "border border-transparent font-medium text-slate-700 hover:border-blue-100 hover:bg-blue-50/70 hover:text-blue-700 dark:text-slate-200 dark:hover:border-sky-700/70 dark:hover:bg-sky-400/10 dark:hover:text-sky-300",
              ]}
            >
              <span
                class:list={[
                  "grid h-[30px] w-[30px] shrink-0 place-items-center rounded-[var(--radius-md)]",
                  homeActive
                    ? "bg-blue-100 text-blue-700 dark:bg-sky-400/20 dark:text-sky-300"
                    : "bg-slate-100 text-slate-500 group-hover:bg-blue-100 group-hover:text-blue-700 dark:bg-slate-800 dark:text-slate-300 dark:group-hover:bg-sky-400/15 dark:group-hover:text-sky-300",
                ]}
              >
                <House class="h-5 w-5" aria-hidden="true" />
              </span>
              <span class="sidebar-link-label truncate">Home</span>
            </a>
          </li>
        </ul>

        <ul class="grid gap-1.5">
          {
            topLevelTools.map((item) => {
              const active = isActive(item.href);
              return (
                <li>
                  <a
                    href={item.href}
                    title={item.label}
                    aria-current={active ? "page" : undefined}
                    class:list={[
                      "sidebar-nav-link group flex h-10 items-center gap-2.5 rounded-[var(--radius-lg)] px-2.5 text-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 dark:focus-visible:outline-sky-400",
                      active
                        ? "border border-blue-200 bg-blue-50/85 font-semibold text-blue-700 dark:border-sky-500/45 dark:bg-sky-400/12 dark:text-sky-200"
                        : "border border-transparent font-medium text-slate-700 hover:border-blue-100 hover:bg-blue-50/70 hover:text-blue-700 dark:text-slate-200 dark:hover:border-sky-700/70 dark:hover:bg-sky-400/10 dark:hover:text-sky-300",
                    ]}
                  >
                    <span
                      class:list={[
                        "grid h-[30px] w-[30px] shrink-0 place-items-center rounded-[var(--radius-md)]",
                        active
                          ? "bg-blue-100 text-blue-700 dark:bg-sky-400/20 dark:text-sky-300"
                          : "bg-slate-100 text-slate-500 group-hover:bg-blue-100 group-hover:text-blue-700 dark:bg-slate-800 dark:text-slate-300 dark:group-hover:bg-sky-400/15 dark:group-hover:text-sky-300",
                      ]}
                    >
                      <item.icon class="h-5 w-5" aria-hidden="true" />
                    </span>

                    <span class="sidebar-link-label truncate">{item.label}</span>
                  </a>
                </li>
              );
            })
          }
        </ul>
      </div>

      <!-- Tool groups -->
      <div>
        <p class="sidebar-section-title mb-2 px-3 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500 dark:text-slate-400">
          Categories
        </p>

        <ul class="sidebar-categories grid gap-2">
          {
            groups.map((group) => {
              const groupHasActive = group.items.some((i) => isActive(i.href));
              return (
              <li class="sidebar-category-item">
                <details
                  class="group/details rounded-[var(--radius-xl)] border border-transparent open:border-blue-200/85 open:bg-blue-50/70 dark:open:border-sky-700/70 dark:open:bg-sky-400/10"
                  open={groupHasActive}
                >
                  <summary class="sidebar-category-summary flex h-10 cursor-pointer list-none items-center justify-between gap-2.5 rounded-[var(--radius-xl)] border border-transparent px-2.5 text-sm font-medium text-slate-700 hover:border-blue-100 hover:bg-blue-50/70 hover:text-blue-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 dark:text-slate-200 dark:hover:border-sky-700/70 dark:hover:bg-sky-400/10 dark:hover:text-sky-300 dark:focus-visible:outline-sky-400">
                    <span class="flex min-w-0 items-center gap-3">
                      <span class="grid h-[30px] w-[30px] shrink-0 place-items-center rounded-[var(--radius-md)] bg-slate-100 text-slate-500 group-hover/details:bg-blue-100 group-hover/details:text-blue-700 dark:bg-slate-800 dark:text-slate-300 dark:group-hover/details:bg-sky-400/15 dark:group-hover/details:text-sky-300">
                        <group.icon class="h-5 w-5" aria-hidden="true" />
                      </span>

                      <span class="sidebar-link-label truncate">{group.title}</span>
                    </span>

                    <span class="sidebar-chevron flex shrink-0 items-center">
                      <ChevronDown
                        size={16}
                        class="text-slate-400 group-open/details:rotate-180 dark:text-slate-500"
                        aria-hidden="true"
                      />
                    </span>
                  </summary>

                  <ul class="sidebar-submenu mx-2.5 mb-2.5 mt-1 grid gap-1 pl-3">
                    {
                      group.items.map((item) => {
                        const subActive = isActive(item.href);
                        return (
                        <li>
                          <a
                            href={item.href}
                            title={item.label}
                            aria-current={subActive ? "page" : undefined}
                            class:list={[
                              "group/item flex min-h-[34px] items-center gap-2 rounded-[var(--radius-md)] px-2 py-1.5 text-[13px] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 dark:focus-visible:outline-sky-400",
                              subActive
                                ? "border border-blue-200/80 bg-blue-50/75 font-medium text-blue-700 dark:border-sky-600/50 dark:bg-sky-400/10 dark:text-sky-200"
                                : "border border-transparent text-slate-700 hover:border-blue-100 hover:bg-blue-50/60 hover:text-blue-800 dark:text-slate-200 dark:hover:border-slate-700 dark:hover:bg-slate-800 dark:hover:text-slate-100",
                            ]}
                          >
                            <span
                              class:list={[
                                "h-1.5 w-1.5 shrink-0 rounded-full",
                                subActive
                                  ? "bg-blue-600 dark:bg-sky-400"
                                  : "bg-slate-400 group-hover/item:bg-blue-600 dark:bg-slate-500 dark:group-hover/item:bg-sky-400",
                              ]}
                              aria-hidden="true"
                            />
                            <span class="truncate">{item.label}</span>
                          </a>
                        </li>
                        );
                      })
                    }
                  </ul>
                </details>
              </li>
              );
            })
          }
        </ul>
      </div>
    </nav>

    <!-- Sidebar footer -->
    <div class="sidebar-footer border-t border-[var(--border-muted)] p-3 dark:border-slate-800">
      <a
        href="/solana-token-management"
        title="Token management hub — guides"
        class="sidebar-footer-link flex items-center justify-between rounded-[var(--radius-xl)] border border-[var(--border)] bg-[var(--muted)]/55 px-3 py-2.5 text-sm font-medium text-slate-700 hover:border-blue-200 hover:bg-blue-50/70 hover:text-blue-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 dark:bg-slate-900 dark:text-slate-200 dark:hover:border-sky-700 dark:hover:bg-sky-400/10 dark:hover:text-sky-300 dark:focus-visible:outline-sky-400"
      >
        <span class="sidebar-footer-text min-w-0">
          <span class="block text-xs font-semibold text-slate-950 dark:text-slate-50">
            Need a guide?
          </span>
          <span class="block text-xs font-normal text-slate-600 dark:text-slate-300">
            Token management hub
          </span>
        </span>

        <span class="sidebar-footer-arrow text-slate-400" aria-hidden="true">→</span>
        <span class="sidebar-footer-icon hidden place-items-center text-slate-600 dark:text-slate-400">
          <BookOpen size={20} aria-hidden="true" />
        </span>
      </a>
    </div>
  </div>
  </aside>
</div>

<script is:inline>
  (() => {
    const root = document.documentElement;
    const toggle = document.getElementById("sidebar-toggle");
    const aside = document.getElementById("app-sidebar");
    const backdrop = document.getElementById("sidebar-backdrop");
    const mobileButton = document.getElementById("mobile-sidebar-button");
    if (!toggle || !aside || !backdrop) return;

    const KEY = "sidebar-collapsed";
    const expandedLabel = "Collapse sidebar";
    const collapsedLabel = "Expand sidebar";
    const isMobileViewport = () => window.innerWidth < 1024;
    const desktopQuery = window.matchMedia("(min-width: 1024px)");
    const expandedIcon = toggle.querySelector(".sidebar-toggle-icon-expanded");
    const collapsedIcon = toggle.querySelector(".sidebar-toggle-icon-collapsed");

    const sync = () => {
      const collapsed = root.classList.contains("sidebar-collapsed");
      const mobileOpen = root.classList.contains("sidebar-mobile-open") && isMobileViewport();
      toggle.setAttribute("aria-expanded", collapsed ? "false" : "true");
      toggle.setAttribute("aria-label", collapsed ? collapsedLabel : expandedLabel);
      expandedIcon?.classList.toggle("hidden", collapsed);
      collapsedIcon?.classList.toggle("hidden", !collapsed);
      backdrop.classList.toggle("hidden", !mobileOpen);
      mobileButton?.setAttribute("aria-expanded", String(mobileOpen));
      aside.classList.toggle("-translate-x-full", !mobileOpen);
      aside.classList.toggle("translate-x-0", mobileOpen);
    };

    if (!isMobileViewport()) {
      root.classList.remove("sidebar-mobile-open");
    }

    sync();
    toggle.addEventListener("click", () => {
      root.classList.toggle("sidebar-collapsed");
      localStorage.setItem(KEY, root.classList.contains("sidebar-collapsed") ? "true" : "false");
      sync();
    });

    mobileButton?.addEventListener("click", () => {
      root.classList.toggle("sidebar-mobile-open");
      sync();
    });

    backdrop.addEventListener("click", () => {
      root.classList.remove("sidebar-mobile-open");
      sync();
    });

    const expandSelectors =
      "a.sidebar-nav-link, summary.sidebar-category-summary, a.sidebar-footer-link, .sidebar-submenu a";

    aside.addEventListener("click", (e) => {
      const t = e.target;
      if (!(t instanceof Element)) return;
      const isNavInteraction = Boolean(t.closest(expandSelectors));

      if (root.classList.contains("sidebar-collapsed") && isNavInteraction) {
        root.classList.remove("sidebar-collapsed");
        localStorage.setItem(KEY, "false");
      }

      if (window.innerWidth < 1024 && t.closest("a")) {
        root.classList.remove("sidebar-mobile-open");
      }

      sync();
    });

    desktopQuery.addEventListener("change", (event) => {
      if (event.matches) {
        root.classList.remove("sidebar-mobile-open");
      }
      sync();
    });

    document.addEventListener("keydown", (event) => {
      if (event.key !== "Escape") return;
      if (!root.classList.contains("sidebar-mobile-open")) return;
      root.classList.remove("sidebar-mobile-open");
      sync();
    });
  })();
</script>

<style is:global>
  html.sidebar-mobile-open {
    overflow: hidden;
  }

  @media (min-width: 1024px) {
    html.sidebar-collapsed .sidebar-root {
      width: var(--sidebar-collapsed-width);
      max-width: var(--sidebar-collapsed-width);
      overflow-x: visible;
      overflow-y: hidden;
    }

    html.sidebar-collapsed .sidebar-root .sidebar-scroll {
      overflow-x: visible;
      padding-left: 0.5rem;
      padding-right: 0.5rem;
    }

    html.sidebar-collapsed .sidebar-root .sidebar-section-title {
      display: none;
    }

    html.sidebar-collapsed .sidebar-root .sidebar-link-label {
      display: none;
    }

    html.sidebar-collapsed .sidebar-root .sidebar-chevron {
      display: none;
    }

    html.sidebar-collapsed .sidebar-root .sidebar-nav-link,
    html.sidebar-collapsed .sidebar-root .sidebar-category-summary {
      justify-content: center;
      padding-left: 0.25rem;
      padding-right: 0.25rem;
      gap: 0;
    }

    html.sidebar-collapsed .sidebar-root .sidebar-category-summary .flex.min-w-0 {
      min-width: 0;
      justify-content: center;
    }

    html.sidebar-collapsed .sidebar-root .sidebar-footer {
      padding: 0.5rem;
    }

    html.sidebar-collapsed .sidebar-root .sidebar-footer-link {
      justify-content: center;
      padding: 0.625rem;
    }

    html.sidebar-collapsed .sidebar-root .sidebar-footer-text,
    html.sidebar-collapsed .sidebar-root .sidebar-footer-arrow {
      display: none;
    }

    html.sidebar-collapsed .sidebar-root .sidebar-footer-icon {
      display: grid;
    }

    html.sidebar-collapsed .sidebar-root .sidebar-category-item {
      position: relative;
      z-index: 1;
    }

    html.sidebar-collapsed .sidebar-root .sidebar-submenu {
      position: absolute;
      left: calc(100% + 0.25rem);
      top: 0;
      margin: 0;
      width: 16rem;
      max-height: min(70vh, 24rem);
      overflow-y: auto;
      padding: 0.5rem;
      padding-left: 0.75rem;
      border-radius: 0.75rem;
      border: 1px solid rgb(226 232 240 / 0.95);
      background: rgb(255 255 255);
      box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.08);
      z-index: 40;
    }

    html.dark.sidebar-collapsed .sidebar-root .sidebar-submenu {
      border-color: rgb(30 41 59 / 0.9);
      background: rgb(15 23 42);
      box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.35);
    }

    html.sidebar-collapsed .sidebar-root details[open] {
      position: relative;
      z-index: 20;
    }
  }
</style>