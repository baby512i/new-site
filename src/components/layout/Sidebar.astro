---
const groups = [
  {
    title: "Token Creation",
    items: [
      { href: "/create/token", label: "Create Token" },
      { href: "/create/metadata", label: "Token Metadata" },
    ],
  },
  {
    title: "Token Management",
    items: [
      { href: "/manage/freeze", label: "Freeze / Unfreeze" },
      { href: "/manage/revoke", label: "Revoke Authorities" },
    ],
  },
  {
    title: "Guides",
    items: [
      { href: "/guides/getting-started", label: "Getting Started" },
      { href: "/guides/security", label: "Security Basics" },
    ],
  },
];
---

<aside class="hidden w-[260px] shrink-0 border-r border-slate-200 bg-white p-4 lg:block dark:border-slate-800 dark:bg-slate-950" aria-label="Sidebar">
  <nav aria-label="Tool navigation">
    <ul class="grid gap-5">
      {
        groups.map((group) => (
          <li>
            <h2 class="mb-2 px-2 text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
              {group.title}
            </h2>
            <ul class="grid gap-1">
              {
                group.items.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      class="flex min-h-11 items-center rounded-md px-3 text-sm font-medium text-slate-700 hover:bg-slate-100 hover:text-slate-900 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-slate-100"
                    >
                      {item.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </li>
        ))
      }
    </ul>
  </nav>
</aside>
