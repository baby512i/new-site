---
import { Check, ChevronDown, Circle, CircleHelp, Menu, Moon, Settings, SlidersHorizontal, Sparkles, Sun, Wallet, X, Zap } from "@lucide/astro";
import Button from "../ui/Button.astro";

---

<header class="sticky top-0 z-50 border-b border-[var(--border-muted)] bg-white/95 supports-[backdrop-filter]:bg-white/85 supports-[backdrop-filter]:backdrop-blur dark:border-slate-800 dark:bg-slate-950/95">
  <div class="mx-auto flex h-14 max-w-7xl items-center justify-between px-3 sm:px-5 lg:px-8">
    <div class="flex items-center gap-2.5">
      <Button
        id="mobile-sidebar-button"
        type="button"
        variant="outline"
        size="icon"
        class="lg:hidden"
        aria-label="Toggle sidebar"
        aria-expanded="false"
        aria-controls="app-sidebar"
      >
        <Menu class="h-5 w-5" aria-hidden="true" />
      </Button>

      <a
        href="/"
        class="hidden items-center gap-2 rounded-[var(--radius-md)] text-slate-950 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 dark:text-slate-50 dark:focus-visible:outline-sky-400 min-[850px]:inline-flex"
        aria-label="Solana tools home"
      >
        <span class="inline-flex h-[34px] w-[34px] items-center justify-center rounded-[var(--radius-md)] bg-blue-600 text-sm font-semibold text-white dark:bg-sky-400 dark:text-slate-950">ST</span>
        <span class="text-[15px] font-semibold tracking-tight">Solana Tools</span>
      </a>
    </div>

    <div class="flex items-center gap-2">
      <Button
        id="mobile-header-settings-button"
        type="button"
        variant="outline"
        size="icon"
        class="min-[850px]:hidden"
        aria-label="Open header settings"
      >
        <Settings class="h-5 w-5" aria-hidden="true" />
      </Button>

      <div class="hidden items-center gap-2 min-[850px]:flex">
        <div id="header-network-picker" class="relative">
          <button
            id="header-network-trigger"
            type="button"
            aria-label="Select Solana network"
            aria-haspopup="menu"
            aria-expanded="false"
            class="inline-flex h-10 items-center gap-2 rounded-[var(--radius-lg)] border border-[var(--border)] bg-[var(--card)] px-3.5 text-sm font-semibold text-[var(--foreground)] outline-none hover:bg-[var(--muted)] focus:border-[var(--ring)] focus:ring-2 focus:ring-[var(--ring-soft)]"
          >
            <span id="header-network-current-icon" class="inline-flex" aria-hidden="true">
              <span class="inline-flex h-5 w-5 items-center justify-center rounded-full border-2 border-emerald-400 bg-emerald-500/15 dark:border-emerald-300 dark:bg-emerald-400/20">
                <span class="h-2 w-2 rounded-full bg-emerald-500 dark:bg-emerald-300"></span>
              </span>
            </span>
            <span id="header-network-current-label">Mainnet</span>
            <ChevronDown class="h-4 w-4 text-[var(--muted-foreground)]" aria-hidden="true" />
          </button>

          <div
            id="header-network-menu"
            role="menu"
            aria-label="Network options"
            class="absolute right-0 top-[calc(100%+0.55rem)] z-50 hidden min-w-52 rounded-[var(--radius-xl)] border border-[var(--border)] bg-[var(--card)] p-2 shadow-[var(--shadow-md)]"
          >
            <button
              type="button"
              role="menuitemradio"
              aria-checked="true"
              data-network-option="mainnet"
              class="flex w-full items-center gap-3 rounded-[var(--radius-md)] px-3 py-3 text-left text-sm font-semibold text-[var(--foreground)] hover:bg-slate-50 dark:text-slate-100 dark:hover:bg-sky-500/10"
            >
              <span class="inline-flex h-4 w-4 items-center justify-center rounded-full border-2 border-emerald-400 bg-emerald-500/15 dark:border-emerald-300 dark:bg-emerald-400/20">
                <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 dark:bg-emerald-300"></span>
              </span>
              <span class="flex-1">Mainnet</span>
              <Check id="header-network-check-mainnet" class="h-4 w-4 text-[var(--primary)]" aria-hidden="true" />
            </button>
            <button
              type="button"
              role="menuitemradio"
              aria-checked="false"
              data-network-option="devnet"
              class="flex w-full items-center gap-3 rounded-[var(--radius-md)] px-3 py-3 text-left text-sm font-semibold text-[var(--foreground)] hover:bg-slate-50 dark:text-slate-100 dark:hover:bg-sky-500/10"
            >
              <Zap class="h-4 w-4 text-amber-500 dark:text-amber-400" aria-hidden="true" />
              <span class="flex-1">Devnet</span>
              <Check id="header-network-check-devnet" class="hidden h-4 w-4 text-[var(--primary)]" aria-hidden="true" />
            </button>
          </div>
        </div>

        <Button
          id="header-fees-button"
          type="button"
          variant="outline"
          size="sm"
          class="h-10 rounded-[var(--radius-lg)] px-3.5 text-sm font-semibold"
          aria-label="Open transaction fee settings"
        >
          <SlidersHorizontal class="h-[18px] w-[18px]" aria-hidden="true" />
          <span id="header-fees-button-label">Fees: Normal</span>
        </Button>

        <Button
          id="header-pro-button"
          type="button"
          variant="soft"
          size="sm"
          class="h-10 rounded-[var(--radius-lg)] border-violet-200 bg-violet-50 px-3.5 text-sm font-semibold text-violet-700 hover:bg-violet-100 dark:border-violet-400/35 dark:bg-violet-500/12 dark:text-violet-300 dark:hover:bg-violet-500/20"
          aria-label="Open PRO plans"
        >
          <Sparkles class="h-[18px] w-[18px]" aria-hidden="true" />
          PRO
        </Button>

        <Button
          id="theme-toggle"
          type="button"
          variant="outline"
          size="icon"
          class="h-10 w-10 rounded-[var(--radius-lg)]"
          aria-label="Toggle color theme"
        >
          <span id="theme-toggle-icon-dark" class="hidden" aria-hidden="true">
            <Sun class="h-5 w-5" aria-hidden="true" />
          </span>
          <span id="theme-toggle-icon-light" aria-hidden="true">
            <Moon class="h-5 w-5" aria-hidden="true" />
          </span>
        </Button>
      </div>
      <Button
        id="wallet-connect-button"
        variant="primary"
        class="h-10 rounded-[var(--radius-lg)] px-3.5 text-sm font-semibold sm:px-4"

        data-wallet-state="disconnected"
        ariaLabel="Connect Solana wallet"
      >
        <span id="wallet-connect-icon" class="inline-flex" aria-hidden="true">
          <Wallet class="h-5 w-5" aria-hidden="true" />
        </span>
        <span id="wallet-connect-label">Connect Wallet</span>
      </Button>
    </div>
  </div>
</header>

<dialog
  id="mobile-header-settings-dialog"
  class="fixed inset-x-2 bottom-2 top-auto m-0 w-auto translate-y-0 overflow-hidden rounded-[var(--modal-radius)] border border-[var(--border-muted)] bg-white p-0 text-[var(--foreground)] shadow-[var(--shadow-lg)] backdrop:bg-slate-950/45 backdrop:backdrop-blur-[1px] dark:bg-slate-900 sm:left-1/2 sm:right-auto sm:top-1/2 sm:bottom-auto sm:w-[min(34rem,calc(100vw-1rem))] sm:-translate-x-1/2 sm:-translate-y-1/2"
  aria-labelledby="mobile-header-settings-title"
>
  <div class="border-b border-[var(--border-muted)] px-5 pb-3.5 pt-3 dark:border-slate-800 sm:px-6 sm:pb-4">
    <div class="mx-auto mb-3 h-1 w-12 rounded-full bg-slate-300/90 dark:bg-slate-700"></div>
    <div class="flex items-center justify-between gap-3">
      <h2 id="mobile-header-settings-title" class="text-[1.2rem] font-semibold tracking-tight text-slate-900 dark:text-slate-100">Header Settings</h2>
      <button
        id="mobile-header-settings-close"
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-[var(--radius-md)] border border-[var(--border-muted)] text-slate-500 hover:bg-slate-100 hover:text-slate-700 focus:outline-none focus:ring-2 focus:ring-[var(--ring-soft)] dark:border-slate-700 dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-slate-200"
        aria-label="Close header settings"
      >
        <X class="h-4 w-4" aria-hidden="true" />
      </button>
    </div>
  </div>

  <div class="space-y-0">
    <section class="space-y-3.5 border-b border-[var(--border-muted)] px-5 py-[18px] dark:border-slate-800 sm:px-6 sm:py-5">
      <p class="text-sm font-medium text-slate-700 dark:text-slate-300">Network</p>
      <div class="grid gap-2.5">
        <button
          id="mobile-network-mainnet"
          type="button"
          class="flex min-h-12 items-center gap-3 rounded-[var(--radius-xl)] border border-slate-200 bg-slate-50/55 px-4 text-left text-[15px] font-medium text-slate-800 hover:bg-slate-100/75 dark:border-slate-700 dark:bg-slate-950/60 dark:text-slate-100 dark:hover:bg-slate-800"
        >
          <span class="inline-flex h-4 w-4 items-center justify-center rounded-full border-2 border-emerald-400 bg-emerald-500/15 dark:border-emerald-300 dark:bg-emerald-400/20">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 dark:bg-emerald-300"></span>
          </span>
          <span class="flex-1 text-left">Mainnet</span>
          <Check id="mobile-network-check-mainnet" class="h-5 w-5 text-blue-600 dark:text-sky-300" aria-hidden="true" />
          <Circle id="mobile-network-unchecked-mainnet" class="hidden h-5 w-5 text-slate-400 dark:text-slate-500" aria-hidden="true" />
        </button>
        <button
          id="mobile-network-devnet"
          type="button"
          class="flex min-h-12 items-center gap-3 rounded-[var(--radius-xl)] border border-slate-200 bg-slate-50/55 px-4 text-left text-[15px] font-medium text-slate-800 hover:bg-slate-100/75 dark:border-slate-700 dark:bg-slate-950/60 dark:text-slate-100 dark:hover:bg-slate-800"
        >
          <Zap class="h-[18px] w-[18px] text-amber-500 dark:text-amber-400" aria-hidden="true" />
          <span class="flex-1 text-left">Devnet</span>
          <Check id="mobile-network-check-devnet" class="hidden h-5 w-5 text-blue-600 dark:text-sky-300" aria-hidden="true" />
          <Circle id="mobile-network-unchecked-devnet" class="h-5 w-5 text-slate-400 dark:text-slate-500" aria-hidden="true" />
        </button>
      </div>
    </section>

    <section class="space-y-3.5 border-b border-[var(--border-muted)] px-5 py-[18px] dark:border-slate-800 sm:px-6 sm:py-5">
      <p class="text-sm font-medium text-slate-700 dark:text-slate-300">Fee Settings</p>
      <Button
        id="mobile-open-fees-button"
        type="button"
        variant="outline"
        fullWidth
        class="min-h-12 justify-between rounded-[var(--radius-xl)] border border-slate-200 bg-slate-50/55 px-4 text-[15px] font-medium text-slate-800 hover:bg-slate-100/75 dark:border-slate-700 dark:bg-slate-950/60 dark:text-slate-100 dark:hover:bg-slate-800"
      >
        <span class="inline-flex items-center gap-3">
          <SlidersHorizontal class="h-[18px] w-[18px] text-blue-600 dark:text-sky-300" aria-hidden="true" />
          Fee Details
        </span>
        <ChevronDown class="-rotate-90 h-4 w-4 text-slate-400 dark:text-slate-500" aria-hidden="true" />
      </Button>
      <Button
        id="mobile-open-pro-button"
        type="button"
        variant="outline"
        fullWidth
        class="min-h-12 justify-between rounded-[var(--radius-xl)] border border-slate-200 bg-slate-50/55 px-4 text-[15px] font-medium text-slate-800 hover:bg-slate-100/75 dark:border-slate-700 dark:bg-slate-950/60 dark:text-slate-100 dark:hover:bg-slate-800"
      >
        <span class="inline-flex items-center gap-3">
          <SlidersHorizontal class="h-[18px] w-[18px] text-blue-600 dark:text-sky-300" aria-hidden="true" />
          PRO Plans
        </span>
        <ChevronDown class="-rotate-90 h-4 w-4 text-slate-400 dark:text-slate-500" aria-hidden="true" />
      </Button>
    </section>

    <section class="px-5 py-[18px] sm:px-6 sm:py-5">
      <Button
        id="mobile-theme-toggle"
        type="button"
        variant="outline"
        fullWidth
        ariaLabel="Toggle color theme"
        class="min-h-12 justify-between rounded-[var(--radius-xl)] border border-slate-200 bg-slate-50/55 px-4 text-[15px] font-medium text-slate-800 hover:bg-slate-100/75 dark:border-slate-700 dark:bg-slate-950/60 dark:text-slate-100 dark:hover:bg-slate-800"
      >
        <span class="inline-flex items-center gap-3">
          <span id="mobile-theme-toggle-icon-dark" class="hidden" aria-hidden="true">
            <Sun class="h-[18px] w-[18px] text-violet-500 dark:text-violet-300" aria-hidden="true" />
          </span>
          <span id="mobile-theme-toggle-icon-light" aria-hidden="true">
            <Moon class="h-[18px] w-[18px] text-violet-500 dark:text-violet-300" aria-hidden="true" />
          </span>
          <span>Toggle Theme</span>
        </span>
        <ChevronDown class="-rotate-90 h-4 w-4 text-slate-400 dark:text-slate-500" aria-hidden="true" />
      </Button>
    </section>
  </div>
</dialog>

<dialog
  id="header-fees-dialog"
  class="fixed inset-x-2 bottom-2 top-auto m-0 w-auto translate-y-0 rounded-[var(--modal-radius)] border border-[var(--border-muted)] bg-white p-0 text-[var(--foreground)] shadow-[var(--shadow-lg)] backdrop:bg-slate-950/45 backdrop:backdrop-blur-[1px] dark:bg-slate-900 sm:left-1/2 sm:right-auto sm:top-1/2 sm:bottom-auto sm:w-[min(35rem,calc(100vw-2rem))] sm:-translate-x-1/2 sm:-translate-y-1/2"
  aria-labelledby="header-fees-title"
>
  <div class="border-b border-[var(--border-muted)] px-5 py-4 dark:border-slate-800 sm:px-6">
    <div class="mx-auto mb-3 h-1 w-12 rounded-full bg-slate-300/90 dark:bg-slate-700 sm:hidden"></div>
    <div class="flex items-center justify-between gap-3">
      <div>
        <h2 id="header-fees-title" class="text-[1.15rem] font-semibold leading-none tracking-tight text-slate-900 dark:text-slate-100">
          Configuration
        </h2>
        <p class="mt-1.5 text-[13px] leading-5 text-slate-500 dark:text-slate-400">
          Adjust network and fee presets for faster transaction confirmation.
        </p>
      </div>
      <button
        id="header-fees-close"
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-[var(--radius-md)] border border-[var(--border-muted)] text-slate-500 hover:bg-slate-100 hover:text-slate-700 focus:outline-none focus:ring-2 focus:ring-[var(--ring-soft)] dark:border-slate-700 dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-slate-200"
        aria-label="Close fee settings"
      >
        <X class="h-4 w-4" aria-hidden="true" />
      </button>
    </div>
  </div>

  <div class="space-y-5 px-5 py-5 sm:px-6 sm:py-6">
    <div class="space-y-2.5">
      <label for="fees-priority-select" class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-800 dark:text-slate-200">
        Priority Fee
        <CircleHelp class="h-4 w-4 text-slate-400 dark:text-slate-500" aria-label="Priority fee help" title="Priority fee affects transaction speed and cost." />
      </label>
      <div class="relative">
        <select
          id="fees-priority-select"
          class="h-[3.05rem] w-full appearance-none rounded-[var(--radius-xl)] border border-[var(--border)] bg-slate-50/70 px-4 pr-10 text-[15px] font-medium text-slate-900 outline-none focus:border-[var(--ring)] focus:ring-2 focus:ring-[var(--ring-soft)] dark:border-slate-700 dark:bg-slate-950/70 dark:text-slate-100"
        >
          <option value="normal" data-fee-sol="0.005">Normal - 0.005 SOL</option>
          <option value="fast" data-fee-sol="0.007">Fast - 0.007 SOL</option>
          <option value="turbo" data-fee-sol="0.01">Turbo - 0.01 SOL</option>
        </select>
        <ChevronDown class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400 dark:text-slate-500" aria-hidden="true" />
      </div>
      <div class="flex flex-wrap gap-1.5">
        <span class="rounded-[var(--radius-full)] border border-slate-200 bg-slate-100/80 px-2.5 py-1 text-xs font-medium text-slate-500 dark:border-slate-700 dark:bg-slate-800/70 dark:text-slate-400">Market 0.00013 SOL</span>
        <span class="rounded-[var(--radius-full)] border border-sky-200/80 bg-sky-50/70 px-2.5 py-1 text-xs font-medium text-sky-700 dark:border-sky-500/30 dark:bg-sky-500/12 dark:text-sky-300">95% 0.007 SOL</span>
      </div>
    </div>

    <div class="space-y-2.5">
      <label for="fees-jito-select" class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-800 dark:text-slate-200">
        Jito Tip
        <CircleHelp class="h-4 w-4 text-slate-400 dark:text-slate-500" aria-label="Jito tip help" title="Jito tip can improve inclusion priority." />
      </label>
      <div class="relative">
        <select
          id="fees-jito-select"
          class="h-[3.05rem] w-full appearance-none rounded-[var(--radius-xl)] border border-[var(--border)] bg-slate-50/70 px-4 pr-10 text-[15px] font-medium text-slate-900 outline-none focus:border-[var(--ring)] focus:ring-2 focus:ring-[var(--ring-soft)] dark:border-slate-700 dark:bg-slate-950/70 dark:text-slate-100"
        >
          <option value="5x" data-fee-sol="0.0005">5X - 0.0005 SOL</option>
          <option value="10x" data-fee-sol="0.001">10X - 0.001 SOL</option>
          <option value="20x" data-fee-sol="0.002">20X - 0.002 SOL</option>
        </select>
        <ChevronDown class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400 dark:text-slate-500" aria-hidden="true" />
      </div>
      <div class="flex flex-wrap gap-1.5">
        <span class="rounded-[var(--radius-full)] border border-slate-200 bg-slate-100/80 px-2.5 py-1 text-xs font-medium text-slate-500 dark:border-slate-700 dark:bg-slate-800/70 dark:text-slate-400">Market 0 SOL</span>
        <span class="rounded-[var(--radius-full)] border border-sky-200/80 bg-sky-50/70 px-2.5 py-1 text-xs font-medium text-sky-700 dark:border-sky-500/30 dark:bg-sky-500/12 dark:text-sky-300">99% 0.0002 SOL</span>
      </div>
    </div>
  </div>
</dialog>

<dialog
  id="header-pro-dialog"
  class="fixed inset-x-2 bottom-2 top-auto m-0 w-auto translate-y-0 rounded-[var(--modal-radius)] border border-[var(--border-muted)] bg-white p-0 text-[var(--foreground)] shadow-[var(--shadow-lg)] backdrop:bg-slate-950/45 backdrop:backdrop-blur-[1px] dark:bg-slate-900 sm:left-1/2 sm:right-auto sm:top-1/2 sm:bottom-auto sm:w-[min(40rem,calc(100vw-2rem))] sm:-translate-x-1/2 sm:-translate-y-1/2"
  aria-labelledby="header-pro-title"
>
  <div class="space-y-4 p-5 sm:space-y-5 sm:p-6">
    <div class="mx-auto h-1 w-12 rounded-full bg-slate-300/90 dark:bg-slate-700 sm:hidden"></div>
    <div class="flex items-start justify-between gap-3 border-b border-[var(--border-muted)] pb-3.5 dark:border-slate-800 sm:pb-4">
      <div>
        <h2 id="header-pro-title" class="text-[1.2rem] font-semibold tracking-tight text-slate-900 dark:text-slate-100">Become PRO</h2>
        <p class="mt-1.5 text-[13px] leading-5 text-slate-500 dark:text-slate-400">PRO unlocks premium SOL tools.</p>
      </div>
      <button
        id="header-pro-close"
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-[var(--radius-md)] border border-[var(--border-muted)] text-slate-500 hover:bg-slate-100 hover:text-slate-700 focus:outline-none focus:ring-2 focus:ring-[var(--ring-soft)] dark:border-slate-700 dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-slate-200"
        aria-label="Close PRO plans"
      >
        <X class="h-4 w-4" aria-hidden="true" />
      </button>
    </div>

    <fieldset class="space-y-2.5 border-0 p-0">
      <legend class="sr-only">Select a PRO plan</legend>

      <label class="group flex min-h-14 cursor-pointer items-center gap-3 rounded-[var(--radius-xl)] border border-slate-200 bg-slate-50/55 px-4 py-3.5 dark:border-slate-700 dark:bg-slate-950/60 has-[:checked]:border-violet-400 has-[:checked]:bg-violet-50/75 dark:has-[:checked]:border-violet-400/65 dark:has-[:checked]:bg-violet-500/10 has-[:focus-visible]:ring-2 has-[:focus-visible]:ring-[var(--ring-soft)]">
        <input
          type="radio"
          name="header-pro-plan"
          value="degen"
          checked
          class="peer sr-only"
        />
        <span
          aria-hidden="true"
          class="flex h-[18px] w-[18px] shrink-0 items-center justify-center rounded-full border border-slate-400 bg-white peer-checked:border-[var(--ring)] dark:border-slate-500 dark:bg-slate-900"
        >
          <span class="h-2 w-2 rounded-full bg-[var(--ring)] opacity-0 group-has-[:checked]:opacity-100"></span>
        </span>
        <span class="min-w-0 flex-1">
          <span class="block text-[15px] font-semibold leading-tight text-slate-900 dark:text-slate-100">Degen Pass</span>
          <span class="mt-1 block text-[13px] leading-4 text-slate-500 dark:text-slate-400">1 day access</span>
        </span>
        <span class="text-[15px] font-semibold text-slate-900 dark:text-sky-300">5 SOL</span>
      </label>

      <label class="group flex min-h-14 cursor-pointer items-center gap-3 rounded-[var(--radius-xl)] border border-slate-200 bg-slate-50/55 px-4 py-3.5 dark:border-slate-700 dark:bg-slate-950/60 has-[:checked]:border-violet-400 has-[:checked]:bg-violet-50/75 dark:has-[:checked]:border-violet-400/65 dark:has-[:checked]:bg-violet-500/10 has-[:focus-visible]:ring-2 has-[:focus-visible]:ring-[var(--ring-soft)]">
        <input type="radio" name="header-pro-plan" value="trenches" class="peer sr-only" />
        <span
          aria-hidden="true"
          class="flex h-[18px] w-[18px] shrink-0 items-center justify-center rounded-full border border-slate-400 bg-white peer-checked:border-[var(--ring)] dark:border-slate-500 dark:bg-slate-900"
        >
          <span class="h-2 w-2 rounded-full bg-[var(--ring)] opacity-0 group-has-[:checked]:opacity-100"></span>
        </span>
        <span class="min-w-0 flex-1">
          <span class="block text-[15px] font-semibold leading-tight text-slate-900 dark:text-slate-100">Trenches Pass</span>
