---
import { ArrowRightLeft, Copy, Globe, Power, Search, Wallet, X } from "@lucide/astro";
import Button from "../ui/Button.astro";
import HeaderBrand from "./header/HeaderBrand.astro";
import HeaderControls from "./header/HeaderControls.astro";
import MobileHeaderControls from "./header/MobileHeaderControls.astro";
import HeaderSettingsDialog from "./header/HeaderSettingsDialog.astro";
import HeaderFeeDialog from "./header/HeaderFeeDialog.astro";
import HeaderProDialog from "./header/HeaderProDialog.astro";
import DialogShell from "../ui/DialogShell.astro";
---

<header
  class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-header)] supports-[backdrop-filter]:backdrop-blur-md"
>
  <div class="mx-auto flex h-14 max-w-screen-2xl items-center gap-2 px-3 sm:px-5 lg:px-8">
    <HeaderBrand />

    <div class="ml-auto flex shrink-0 items-center gap-2">
      <MobileHeaderControls />
      <HeaderControls />

      <Button
        id="wallet-connect-button"
        variant="primary"
        class="h-10 max-w-[8.75rem] rounded-[var(--radius-lg)] px-2.5 text-sm font-semibold min-[380px]:max-w-none min-[380px]:px-3 min-[1024px]:px-3.5 min-[1200px]:px-4"
        data-wallet-state="disconnected"
        ariaLabel="Connect Solana wallet"
      >
        <span id="wallet-connect-icon" class="inline-flex" aria-hidden="true">
          <Wallet class="h-5 w-5" aria-hidden="true" />
        </span>
        <span id="wallet-connect-label" class="min-w-0 truncate">
          <span data-wallet-label="disconnected" class="inline-flex min-w-0 items-center">
            <span class="inline min-[380px]:hidden">Connect</span>
            <span class="hidden min-[380px]:inline min-[1200px]:hidden">Wallet</span>
            <span class="hidden min-[1200px]:inline">Connect Wallet</span>
          </span>
          <span data-wallet-label="connected" class="hidden min-w-0 truncate"></span>
        </span>
      </Button>
    </div>
  </div>
</header>

<HeaderSettingsDialog />
<HeaderFeeDialog />
<HeaderProDialog />
<DialogShell
  id="wallet-account-dialog"
  labelledBy="wallet-account-title"
  widthClass="w-[min(26rem,calc(100vw-1rem))]"
  class="backdrop:bg-[var(--color-dialog-backdrop-strong)] backdrop:backdrop-blur-[2px]"
>
  <div class="dialog-header px-5 pb-4 pt-4 sm:px-6">
    <div class="mx-auto mb-3 h-1 w-12 rounded-full bg-[var(--color-text-muted)]/35 sm:hidden"></div>
    <div class="flex items-start justify-between gap-3">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--color-text-muted)]">
          Connected Wallet
        </p>
        <h2 id="wallet-account-title" class="dialog-title mt-1">
          Wallet Details
        </h2>
      </div>
      <button
        id="wallet-account-close"
        type="button"
        class="dialog-close-button inline-flex h-11 w-11 items-center justify-center rounded-[var(--radius-xl)] border border-[var(--color-border)]/80 bg-[var(--color-surface)]/90 text-[var(--color-text-muted)] focus:outline-none hover:bg-[var(--color-surface-muted)] hover:text-[var(--color-text)]"
        aria-label="Close wallet details"
      >
        <X class="h-5 w-5" aria-hidden="true" />
      </button>
    </div>
  </div>

  <div class="space-y-4 border-t border-[var(--color-border)] px-5 py-5 sm:px-6">
    <div class="rounded-[var(--radius-2xl)] border border-[var(--color-border)]/80 bg-[var(--color-surface-muted)] p-4">
      <div class="flex items-center gap-3">
        <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-[var(--color-brand-border)] bg-[var(--color-brand-soft)] text-[var(--color-brand-text)]">
          <Wallet class="h-5 w-5" aria-hidden="true" />
        </div>
        <div class="min-w-0 flex-1">
          <p id="wallet-account-short-address" class="truncate text-base font-semibold text-[var(--color-text)]">
            Not connected
          </p>
          <p id="wallet-account-full-address" class="mt-1 truncate text-xs text-[var(--color-text-muted)]"></p>
        </div>
      </div>

      <div class="mt-4 grid grid-cols-2 gap-2">
        <div class="rounded-[var(--radius-xl)] border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2">
          <!-- Intentional 11px: micro metadata label inside compact wallet stats grid. -->
          <p class="text-[11px] font-medium uppercase tracking-[0.12em] text-[var(--color-text-muted)]">Network</p>
          <p class="mt-1 flex items-center gap-1.5 text-sm font-semibold text-[var(--color-text)]">
            <Globe class="h-4 w-4 text-[var(--color-text-muted)]" aria-hidden="true" />
            <span id="wallet-account-network">Mainnet</span>
          </p>
        </div>
        <div class="rounded-[var(--radius-xl)] border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2">
          <!-- Intentional 11px: micro metadata label inside compact wallet stats grid. -->
          <p class="text-[11px] font-medium uppercase tracking-[0.12em] text-[var(--color-text-muted)]">Status</p>
          <p class="mt-1 flex items-center gap-2 text-sm font-semibold">
            <span id="wallet-account-status-dot" class="h-2.5 w-2.5 rounded-full bg-[var(--color-success)] opacity-85" aria-hidden="true"></span>
            <span id="wallet-account-status" class="text-[var(--color-success)]">Connected</span>
          </p>
        </div>
      </div>
    </div>

    <div class="dialog-action-list">
      <button
        id="wallet-account-copy"
        type="button"
        class="flex min-h-11 w-full items-center justify-between rounded-[var(--radius-xl)] border border-[var(--color-border)]/85 bg-[var(--color-surface)] px-4 text-left text-sm font-semibold text-[var(--color-text)] hover:bg-[var(--color-nav-hover)]"
      >
        <span class="inline-flex items-center gap-2.5">
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-[var(--color-border)]/80 bg-[var(--color-surface-muted)]">
            <Copy class="h-4 w-4 text-[var(--color-text-muted)]" aria-hidden="true" />
          </span>
          <span>Copy address</span>
        </span>
        <span id="wallet-account-copy-state" class="text-xs font-medium text-[var(--color-text-muted)]">Copy</span>
      </button>

      <a
        id="wallet-account-explorer"
        href="#"
        target="_blank"
        rel="noreferrer"
        class="flex min-h-11 w-full items-center justify-between rounded-[var(--radius-xl)] border border-[var(--color-border)]/85 bg-[var(--color-surface)] px-4 text-left text-sm font-semibold text-[var(--color-text)] hover:bg-[var(--color-nav-hover)]"
      >
        <span class="inline-flex items-center gap-2.5">
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-[var(--color-border)]/80 bg-[var(--color-surface-muted)]">
            <Search class="h-4 w-4 text-[var(--color-text-muted)]" aria-hidden="true" />
          </span>
          <span>View on Solscan</span>
        </span>
        <span class="text-xs font-medium text-[var(--color-text-muted)]">Open</span>
      </a>

      <button
        id="wallet-account-change"
        type="button"
        class="flex min-h-11 w-full items-center justify-between rounded-[var(--radius-xl)] border border-[var(--color-brand-border)] bg-[var(--color-brand)] px-4 text-left text-sm font-semibold text-[var(--color-text-inverse)] hover:bg-[var(--color-brand-hover)]"
      >
        <span class="inline-flex items-center gap-2.5">
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-[var(--color-brand-border)] bg-[var(--color-brand-soft)] text-[var(--color-brand-text)]">
            <ArrowRightLeft class="h-4 w-4" aria-hidden="true" />
          </span>
          <span>Change wallet</span>
        </span>
        <span class="text-xs font-medium text-[var(--color-text-inverse)]/90">Switch</span>
      </button>

      <button
        id="wallet-account-disconnect"
        type="button"
        class="flex min-h-11 w-full items-center justify-between rounded-[var(--radius-xl)] border border-[var(--color-danger-border)] bg-[var(--color-danger-soft)] px-4 text-left text-sm font-semibold text-[var(--color-danger-text)] hover:bg-[var(--color-danger-hover)] hover:text-[var(--color-text-inverse)]"
      >
        <span class="inline-flex items-center gap-2.5">
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-[var(--color-danger-border)] bg-[var(--color-danger-soft)]">
            <Power class="h-4 w-4" aria-hidden="true" />
          </span>
          <span>Disconnect</span>
        </span>
        <span class="text-xs font-medium">Exit</span>
      </button>
    </div>
  </div>
</DialogShell>

<script>
  import "../../scripts/header/theme.ts";
  import "../../scripts/header/network.ts";
  import "../../scripts/header/dialogs.ts";
  import "../../scripts/header/wallet-network-sync.ts";
  import "../../scripts/header/wallet-account-menu.ts";
  import "../../scripts/header/wallet-button.ts";
</script>
