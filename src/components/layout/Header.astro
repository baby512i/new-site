---
import { Menu, Moon, Sun } from "@lucide/astro";
import Button from "../ui/Button.astro";

---

<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur dark:border-slate-800 dark:bg-slate-950/95">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-2">
      <Button
        id="mobile-sidebar-button"
        type="button"
        variant="outline"
        size="icon"
        class="lg:hidden"
        aria-label="Toggle sidebar"
        aria-expanded="false"
        aria-controls="app-sidebar"
      >
        <Menu class="h-5 w-5" aria-hidden="true" />
      </Button>

      <a
        href="/"
        class="inline-flex items-center gap-2 rounded-md text-slate-950 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 dark:text-slate-50 dark:focus-visible:outline-sky-400"
        aria-label="Solana tools home"
      >
        <span class="inline-flex h-9 w-9 items-center justify-center rounded-md bg-blue-600 text-sm font-semibold text-white dark:bg-sky-400 dark:text-slate-950">ST</span>
        <span class="text-sm font-semibold tracking-tight sm:text-base">Solana Tools</span>
      </a>
    </div>

    <div class="flex items-center gap-2">
          <Button
        id="theme-toggle"
        type="button"
        variant="outline"
        size="icon"
        aria-label="Toggle color theme"
      >
        <span id="theme-toggle-icon-dark" class="hidden" aria-hidden="true">
          <Sun class="h-5 w-5" aria-hidden="true" />
        </span>
        <span id="theme-toggle-icon-light" aria-hidden="true">
          <Moon class="h-5 w-5" aria-hidden="true" />
        </span>
      </Button>
      
<Button
  id="wallet-connect-button"
  variant="primary"
  data-wallet-state="disconnected"
  ariaLabel="Connect Solana wallet"
>
  Connect Wallet
</Button>



    </div>
  </div>
</header>

<script is:inline>
  const root = document.documentElement;
  const themeButton = document.getElementById("theme-toggle");
  const darkIcon = document.getElementById("theme-toggle-icon-dark");
  const lightIcon = document.getElementById("theme-toggle-icon-light");

  const setThemeIcon = () => {
    const isDark = root.classList.contains("dark");
    darkIcon?.classList.toggle("hidden", !isDark);
    lightIcon?.classList.toggle("hidden", isDark);
  };

  setThemeIcon();

  themeButton?.addEventListener("click", () => {
    const isDark = root.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
    setThemeIcon();
  });

</script>

<script>
  const walletButton = document.getElementById("wallet-connect-button");
  const WALLET_CACHE_KEY = "solana-wallet-address";

  const isLikelySolanaAddress = (value) => {
    if (typeof value !== "string") return false;
    if (value.length < 32 || value.length > 44) return false;
    return /^[1-9A-HJ-NP-Za-km-z]+$/.test(value);
  };

  const shortAddress = (address) => `${address.slice(0, 4)}...${address.slice(-4)}`;

  const setWalletButtonState = (state, address) => {
    if (!(walletButton instanceof HTMLButtonElement)) return;

    walletButton.dataset.walletState = state;
    if (state === "loading" || state === "verifying") {
      walletButton.setAttribute("aria-busy", "true");
    } else {
      walletButton.removeAttribute("aria-busy");
    }

    if (state === "loading") {
      walletButton.textContent = "Loading...";
      walletButton.setAttribute("aria-label", "Loading Solana wallet");
      return;
    }

    if (address && isLikelySolanaAddress(address)) {
      const short = shortAddress(address);
      walletButton.textContent = short;
      walletButton.setAttribute("aria-label", `Connected Solana wallet ${short}`);
      return;
    }

    walletButton.textContent = "Connect Wallet";
    walletButton.setAttribute("aria-label", "Connect Solana wallet");
  };

  // Dynamic import dedupe.
  let walletModulePromise = null;
  const loadWalletModule = () => {
    if (!walletModulePromise) {
      walletModulePromise = import("../../lib/wallet/reown-client");
    }
    return walletModulePromise;
  };

  let walletUnsubscribe = null;
  let refreshIntervalId = null;
  let reownLoaded = false;
  let hasBoundVisibilityHandlers = false;
  let isRefreshingWallet = false;

  const clearRefreshLoop = () => {
    if (refreshIntervalId) {
      window.clearInterval(refreshIntervalId);
      refreshIntervalId = null;
    }
  };

  const refreshButtonOnce = async (wallet, maxMs = 1000) => {
    if (!wallet) return;
    if (isRefreshingWallet) return;

    isRefreshingWallet = true;

    try {
      const status = await wallet.refreshSolanaWalletStatus(maxMs);
      if (status?.isConnected && status?.address) {
        setWalletButtonState("connected", status.address);
      } else {
        setWalletButtonState("disconnected", null);
      }
    } catch (error) {
      console.debug("Wallet refresh error:", error);
    } finally {
      isRefreshingWallet = false;
    }
  };

  const startTempRefreshLoop = async (wallet, maxAttempts = 12, everyMs = 400) => {
    if (!wallet) return;
    if (!reownLoaded) return;

    clearRefreshLoop();

    let attempts = 0;
    refreshIntervalId = window.setInterval(async () => {
      attempts += 1;
      await refreshButtonOnce(wallet, 1000);

      if (attempts >= maxAttempts) {
        clearRefreshLoop();
      }
    }, everyMs);
  };

  const ensureWalletSubscription = async (wallet) => {
    if (walletUnsubscribe) return;

    walletUnsubscribe = await wallet.subscribeSolanaWalletStatus((status) => {
      if (status?.isConnected && status?.address) {
        setWalletButtonState("connected", status.address);
      } else {
        setWalletButtonState("disconnected", null);
      }

      // Phantom/Reown can lag — do a short follow-up refresh burst.
      startTempRefreshLoop(wallet, 10, 350);
    });
  };

  const bindPostLoadVisibilityHandlers = (wallet) => {
    if (hasBoundVisibilityHandlers) return;
    hasBoundVisibilityHandlers = true;

    window.addEventListener("focus", () => {
      if (!reownLoaded) return;
      startTempRefreshLoop(wallet, 10, 400);
    });

    document.addEventListener("visibilitychange", () => {
      if (!reownLoaded) return;
      if (document.visibilityState === "visible") {
        startTempRefreshLoop(wallet, 10, 400);
      }
    });
  };

  const updateFromCache = () => {
    if (!(walletButton instanceof HTMLButtonElement)) return;
    const cached = window.localStorage.getItem(WALLET_CACHE_KEY);

    if (cached && isLikelySolanaAddress(cached)) {
      // Display cache immediately, but treat as unverified until Reown checks.
      setWalletButtonState("verifying", cached);
      return cached;
    }

    setWalletButtonState("disconnected", null);
    return null;
  };

  const cachedAddress = updateFromCache();

  // Cross-tab: keep the header button in sync.
  window.addEventListener("storage", (event) => {
    if (event.key !== WALLET_CACHE_KEY) return;
    if (typeof event.newValue === "string" && isLikelySolanaAddress(event.newValue)) {
      setWalletButtonState("verifying", event.newValue);
      window.setTimeout(async () => {
        try {
          const wallet = await loadWalletModule();
          reownLoaded = true;
          await ensureWalletSubscription(wallet);
          bindPostLoadVisibilityHandlers(wallet);
          await refreshButtonOnce(wallet, 1000);
        } catch {
          // Keep cached verifying state if verification fails.
        }
      }, 600);
    } else {
      setWalletButtonState("disconnected", null);
    }
  });

  // Returning users only: verify after idle (do not load Reown for first-time visitors).
  const scheduleIdleVerification = () => {
    if (!cachedAddress) return;

    const run = async () => {
      try {
        const wallet = await loadWalletModule();
        reownLoaded = true;

        await ensureWalletSubscription(wallet);
        bindPostLoadVisibilityHandlers(wallet);

        const status = await wallet.refreshSolanaWalletStatus(2500);
        if (status?.isConnected && status?.address) {
          setWalletButtonState("connected", status.address);
        } else {
          setWalletButtonState("disconnected", null);
        }
      } catch (error) {
        console.debug("Idle wallet verification failed:", error);
        const cached = window.localStorage.getItem(WALLET_CACHE_KEY);
        if (cached && isLikelySolanaAddress(cached)) {
          setWalletButtonState("verifying", cached);
        } else {
          setWalletButtonState("disconnected", null);
        }
      }
    };

    if ("requestIdleCallback" in window) {
      window.requestIdleCallback(run, { timeout: 1800 });
    } else {
      window.setTimeout(run, 900);
    }
  };

  scheduleIdleVerification();

  walletButton?.addEventListener("click", async () => {
    if (!(walletButton instanceof HTMLButtonElement)) return;

    try {
      walletButton.disabled = true;
      setWalletButtonState("loading", null);

      const wallet = await loadWalletModule();
      reownLoaded = true;

      // Subscriptions must start before any modal view opens.
      await ensureWalletSubscription(wallet);
      bindPostLoadVisibilityHandlers(wallet);

      // Force-refresh so we don't open the wrong view with stale state.
      const status = await wallet.refreshSolanaWalletStatus(2500);

      if (status?.isConnected && status?.address) {
        setWalletButtonState("connected", status.address);
        await wallet.openSolanaAccountModal();
      } else {
        setWalletButtonState("disconnected", null);
        await wallet.openSolanaConnectModal();
      }

      // Catch delayed Phantom/Reown updates after open/close/connect flows.
      await refreshButtonOnce(wallet, 1000);
      startTempRefreshLoop(wallet, 12, 400);
    } catch (error) {
      console.error("Failed to open Solana wallet modal:", error);
      setWalletButtonState("error", null);
      window.setTimeout(() => {
        // Return to cached display if it exists; otherwise default.
        const cached = window.localStorage.getItem(WALLET_CACHE_KEY);
        if (cached && isLikelySolanaAddress(cached)) {
          setWalletButtonState("verifying", cached);
        } else {
          setWalletButtonState("disconnected", null);
        }
      }, 1500);
    } finally {
      walletButton.disabled = false;
    }
  });
</script>
