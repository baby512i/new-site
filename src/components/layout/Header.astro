---
import { Menu, Moon, Sun } from "@lucide/astro";
---

<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur dark:border-slate-800 dark:bg-slate-950/95">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-2">
      <button
        id="mobile-sidebar-button"
        type="button"
        class="inline-flex min-h-11 min-w-11 items-center justify-center rounded-md border border-slate-300 bg-white text-slate-700 hover:bg-slate-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 lg:hidden dark:border-slate-700 dark:bg-slate-950 dark:text-slate-200 dark:hover:bg-slate-900 dark:focus-visible:outline-sky-400"
        aria-label="Toggle sidebar"
        aria-expanded="false"
        aria-controls="app-sidebar"
      >
        <Menu class="h-5 w-5" aria-hidden="true" />
      </button>

      <a
        href="/"
        class="inline-flex items-center gap-2 rounded-md text-slate-950 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 dark:text-slate-50 dark:focus-visible:outline-sky-400"
        aria-label="Solana tools home"
      >
        <span class="inline-flex h-9 w-9 items-center justify-center rounded-md bg-blue-600 text-sm font-semibold text-white dark:bg-sky-400 dark:text-slate-950">ST</span>
        <span class="text-sm font-semibold tracking-tight sm:text-base">Solana Tools</span>
      </a>
    </div>

    <div class="flex items-center gap-2">
          <button
        id="theme-toggle"
        type="button"
        class="inline-flex min-h-11 min-w-11 items-center justify-center rounded-md border border-slate-300 bg-white text-slate-700 hover:bg-slate-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-200 dark:hover:bg-slate-900 dark:focus-visible:outline-sky-400"
        aria-label="Toggle color theme"
      >
        <span id="theme-toggle-icon-dark" class="hidden" aria-hidden="true">
          <Sun class="h-5 w-5" aria-hidden="true" />
        </span>
        <span id="theme-toggle-icon-light" aria-hidden="true">
          <Moon class="h-5 w-5" aria-hidden="true" />
        </span>
      </button>
      
      <button
        id="wallet-connect-button"
        type="button"
        class="inline-flex min-h-11 items-center justify-center rounded-md border border-slate-300 bg-white px-4 text-sm font-semibold text-slate-700 hover:bg-slate-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 disabled:cursor-not-allowed disabled:opacity-60 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-200 dark:hover:bg-slate-900 dark:focus-visible:outline-sky-400"
        aria-label="Connect Solana wallet"
      >
        Connect Wallet
      </button>



    </div>
  </div>
</header>

<script is:inline>
  const root = document.documentElement;
  const themeButton = document.getElementById("theme-toggle");
  const darkIcon = document.getElementById("theme-toggle-icon-dark");
  const lightIcon = document.getElementById("theme-toggle-icon-light");

  const setThemeIcon = () => {
    const isDark = root.classList.contains("dark");
    darkIcon?.classList.toggle("hidden", !isDark);
    lightIcon?.classList.toggle("hidden", isDark);
  };

  setThemeIcon();

  themeButton?.addEventListener("click", () => {
    const isDark = root.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
    setThemeIcon();
  });

</script>

<script>
  const walletButton = document.getElementById("wallet-connect-button");
  const WALLET_CACHE_KEY = "solana-wallet-address";

  const shortAddress = (address) => `${address.slice(0, 4)}...${address.slice(-4)}`;
  const delay = (ms) => new Promise((resolve) => setTimeout(resolve, ms));
  let walletUnsubscribe = null;

  const setWalletButtonConnectedState = (address) => {
    if (!(walletButton instanceof HTMLButtonElement)) return;

    if (!address) {
      walletButton.textContent = "Connect Wallet";
      walletButton.setAttribute("aria-label", "Connect Solana wallet");
      return;
    }

    walletButton.textContent = shortAddress(address);
    walletButton.setAttribute("aria-label", `Connected Solana wallet ${shortAddress(address)}`);
  };

  if (walletButton instanceof HTMLButtonElement) {
    const cachedAddress = window.localStorage.getItem(WALLET_CACHE_KEY);
    setWalletButtonConnectedState(cachedAddress);
  }

  const refreshWalletButtonState = async (walletModule, attempts = 8, waitMs = 250) => {
    for (let index = 0; index < attempts; index += 1) {
      const status = await walletModule.getSolanaWalletStatus();

      if (status?.address) {
        setWalletButtonConnectedState(status.address);
        return;
      }

      if (index < attempts - 1) {
        await delay(waitMs);
      }
    }

    setWalletButtonConnectedState(null);
  };

  const ensureWalletSubscription = async (walletModule) => {
    if (walletUnsubscribe) {
      return;
    }

    walletUnsubscribe = await walletModule.subscribeSolanaWalletStatus((status) => {
      setWalletButtonConnectedState(status?.address || null);
    });
  };

  walletButton?.addEventListener("click", async () => {
    if (!(walletButton instanceof HTMLButtonElement)) return;

    const originalText = walletButton.textContent || "Connect Wallet";

    try {
      walletButton.disabled = true;
      walletButton.textContent = "Loading Wallet...";

      const wallet = await import("../../lib/wallet/reown-client");
      await ensureWalletSubscription(wallet);
      await wallet.openSolanaWalletModal();
      await refreshWalletButtonState(wallet);
    } catch (error) {
      console.error("Failed to open Solana wallet modal:", error);
      walletButton.textContent = "Wallet Error";

      window.setTimeout(() => {
        walletButton.textContent = originalText;
      }, 1800);
    } finally {
      walletButton.disabled = false;

      if (walletButton.textContent === "Loading Wallet...") {
        walletButton.textContent = originalText;
      }
    }
  });
</script>
