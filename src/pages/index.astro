---
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/ui/Card.astro";
import Button from "../components/ui/Button.astro";
import {
  ArrowRight,
  BookOpen,
  Briefcase,
  Coins,
  Droplets,
  FileImage,
  Flame,
  LockKeyholeOpen,
  Shield,
  ShieldCheck,
  Sparkles,
  WalletMinimal,
} from "@lucide/astro";

const popularTools = [
  {
    title: "Create Solana Token",
    description: "Launch a new SPL token with guided settings.",
    href: "/create-solana-token",
    icon: Coins,
  },
  {
    title: "Mint Solana Token",
    description: "Mint additional supply for an existing token.",
    href: "/mint-solana-token",
    icon: Sparkles,
  },
  {
    title: "Burn Solana Token",
    description: "Permanently reduce token supply.",
    href: "/burn-solana-token",
    icon: Flame,
  },
  {
    title: "Update Token Metadata",
    description: "Edit token metadata with clear authority requirements.",
    href: "/update-solana-token-metadata",
    icon: FileImage,
  },
  {
    title: "Revoke Mint Authority",
    description: "Disable future minting for stronger holder trust.",
    href: "/revoke-mint-authority",
    icon: LockKeyholeOpen,
  },
  {
    title: "Create Liquidity Pool",
    description: "Prepare liquidity creation workflows for Solana markets.",
    href: "/create-solana-liquidity-pool",
    icon: Droplets,
  },
] as const;

const resources = [
  {
    title: "Getting Started",
    description: "Learn the basics before creating or managing a Solana token.",
    href: "/guides/getting-started",
    icon: BookOpen,
  },
  {
    title: "Token Standards",
    description: "Understand SPL Token and Token-2022 differences before choosing a workflow.",
    href: "/guides/solana-token-standards",
    icon: Shield,
  },
  {
    title: "Safety Best Practices",
    description: "Avoid common authority, liquidity, and wallet-signing mistakes.",
    href: "/safety",
    icon: ShieldCheck,
  },
  {
    title: "Solana Token Management",
    description: "Explore tools for minting, burning, metadata, holders, and authority actions.",
    href: "/solana-token-management",
    icon: Briefcase,
  },
] as const;

/** Shared homepage icon shell (trust, tools, resources). */
const homeIconBox =
  "flex h-9 w-9 shrink-0 items-center justify-center rounded-[var(--radius-md)] border border-[var(--color-brand-border)] bg-[var(--color-brand-soft)] text-[var(--color-brand-text)]";

const trustSignals = [
  {
    label: "Non-custodial by design",
    icon: ShieldCheck,
  },
  {
    label: "Read workflows before connecting",
    icon: BookOpen,
  },
  {
    label: "Wallet signs only after you confirm",
    icon: WalletMinimal,
  },
  {
    label: "Fast, Astro-first public pages",
    icon: Sparkles,
  },
] as const;
---

<BaseLayout
  title="Solana Tools"
  description="Lightweight non-custodial Solana tools for token creation, token management, liquidity, and wallet workflows."
>
  <div class="space-y-10 pb-4">
    <section
      class="grid gap-8 rounded-[var(--radius-2xl)] border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[var(--shadow-xs)] sm:p-7 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:gap-10 lg:p-10"
    >
      <div class="min-w-0">
        <p
          class="mb-4 inline-flex max-w-full items-center rounded-[var(--radius-full)] border border-[var(--color-brand-border)] bg-[var(--color-brand-soft)] px-3 py-1 text-sm font-medium text-[var(--color-brand-text)]"
        >
          Non-custodial Solana tools
        </p>

        <h1
          class="max-w-3xl text-4xl font-semibold leading-tight tracking-[var(--tracking-heading)] text-[var(--color-text)] sm:text-5xl"
        >
          The modern toolkit for Solana builders
        </h1>

        <p class="mt-5 max-w-2xl text-base leading-[var(--leading-body)] text-[var(--color-text-secondary)]">
          Create tokens, manage authorities, prepare liquidity actions, and use wallet utilities through
          lightweight tools built for speed, clarity, and safer on-chain workflows.
        </p>

        <div class="mt-6 flex flex-wrap gap-2">
          <span
            class="rounded-[var(--radius-full)] border border-[var(--color-border)] bg-[var(--color-surface-muted)] px-3 py-1 text-sm text-[var(--color-text-secondary)]"
            >Non-custodial</span
          >
          <span
            class="rounded-[var(--radius-full)] border border-[var(--color-border)] bg-[var(--color-surface-muted)] px-3 py-1 text-sm text-[var(--color-text-secondary)]"
            >Wallet signs only on action</span
          >
          <span
            class="rounded-[var(--radius-full)] border border-[var(--color-border)] bg-[var(--color-surface-muted)] px-3 py-1 text-sm text-[var(--color-text-secondary)]"
            >Fast Astro-first pages</span
          >
        </div>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
          <Button href="/create-solana-token" variant="primary" size="lg">Explore Tools</Button>
          <Button href="/safety" variant="outline" size="lg">Read Safety Notes</Button>
        </div>
      </div>

      <div
        class="relative order-last min-h-[240px] overflow-hidden rounded-[var(--radius-2xl)] border border-[var(--color-border)] bg-[var(--color-surface-muted)] sm:min-h-[280px] lg:order-none lg:min-h-[380px]"
      >
        <div class="hero-art absolute inset-0" aria-hidden="true"></div>

        <div
          class="pointer-events-none absolute bottom-4 left-4 max-w-[14rem] rounded-[var(--radius-xl)] border border-[var(--color-border)] bg-[var(--color-surface-overlay)] px-3 py-2.5 shadow-[var(--shadow-md)] sm:bottom-5 sm:left-5 sm:max-w-[15rem] sm:px-4 sm:py-3"
        >
          <p class="text-xs text-[var(--color-text-muted)]">Built for</p>
          <p class="text-base font-semibold text-[var(--color-text)] sm:text-lg">Fast Solana workflows</p>
        </div>
      </div>
    </section>

    <section aria-labelledby="trust-heading" class="rounded-[var(--radius-2xl)] border border-[var(--color-border)] bg-[var(--color-surface-muted)] px-4 py-5 sm:px-6 sm:py-6">
      <h2 id="trust-heading" class="sr-only">Trust and product signals</h2>
      <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {
          trustSignals.map((item) => {
            const TrustIcon = item.icon;
            return (
              <li
                class="flex h-full min-h-[calc(var(--control-lg)_*_2_+_var(--control-sm))] items-start gap-3 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-5 shadow-[var(--shadow-xs)]"
              >
                <span class={homeIconBox}>
                  <TrustIcon class="size-[1.125rem] shrink-0 stroke-[currentColor]" aria-hidden="true" />
                </span>
                <span class="text-sm font-medium leading-[var(--leading-body)] text-[var(--color-text)]"
                  >{item.label}</span
                >
              </li>
            );
          })
        }
      </ul>
    </section>

    <section aria-labelledby="popular-tools-heading">
      <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h2
            id="popular-tools-heading"
            class="text-2xl font-semibold tracking-[var(--tracking-heading)] text-[var(--color-text)]"
          >
            Popular Tools
          </h2>
          <p class="mt-2 text-sm leading-[var(--leading-body)] text-[var(--color-text-muted)]">
            Quick access to the most used Solana workflows.
          </p>
        </div>
        <a
          href="/solana-token-management"
          class="hidden text-sm font-semibold text-[var(--color-brand-text)] transition-colors hover:text-[var(--color-brand-hover)] sm:inline"
        >
          View all tools →
        </a>
      </div>

      <div class="grid grid-cols-1 items-stretch gap-4 sm:grid-cols-2 xl:grid-cols-3">
        {
          popularTools.map((tool) => {
            const ToolIcon = tool.icon;
            return (
              <Card
                as="article"
                size="sm"
                class="group flex h-full min-h-0 flex-col transition-colors hover:border-[var(--color-nav-active-border)] hover:bg-[var(--color-brand-soft)]"
              >
                <div class="flex min-h-0 flex-1 flex-col gap-3">
                  <div class="flex min-h-0 flex-1 items-stretch gap-3">
                    <span class={homeIconBox}>
                      <ToolIcon class="size-[1.125rem] shrink-0 stroke-[currentColor]" aria-hidden="true" />
                    </span>
                    <div class="flex min-h-0 flex-1 flex-col">
                      <h3 class="text-base font-semibold leading-[var(--leading-title)] text-[var(--color-text)]">
                        <a href={tool.href} class="transition-colors hover:text-[var(--color-brand-text)]">
                          {tool.title}
                        </a>
                      </h3>
                      <p class="mt-2 flex-1 text-sm leading-[var(--leading-body)] text-[var(--color-text-muted)]">
                        {tool.description}
                      </p>
                      <a
                        href={tool.href}
                        class="mt-auto inline-flex items-center gap-1.5 pt-4 text-sm font-semibold text-[var(--color-brand-text)] transition-colors hover:text-[var(--color-brand-hover)]"
                      >
                        Open tool
                        <ArrowRight class="size-4 shrink-0 stroke-[currentColor]" aria-hidden="true" />
                      </a>
                    </div>
                  </div>
                </div>
              </Card>
            );
          })
        }
      </div>

      <a
        href="/solana-token-management"
        class="mt-4 inline-flex text-sm font-semibold text-[var(--color-brand-text)] transition-colors hover:text-[var(--color-brand-hover)] sm:hidden"
      >
        View all tools →
      </a>
    </section>

    <section aria-labelledby="resources-heading">
      <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h2
            id="resources-heading"
            class="text-2xl font-semibold tracking-[var(--tracking-heading)] text-[var(--color-text)]"
          >
            Resources
          </h2>
          <p class="mt-2 text-sm leading-[var(--leading-body)] text-[var(--color-text-muted)]">
            Guides, explanations, and safety references for Solana token workflows.
          </p>
        </div>
        <a
          href="/guides"
          class="hidden text-sm font-semibold text-[var(--color-brand-text)] transition-colors hover:text-[var(--color-brand-hover)] sm:inline"
        >
          View resources →
        </a>
      </div>

      <div class="grid grid-cols-1 items-stretch gap-4 md:grid-cols-2">
        {
          resources.map((item) => {
            const ResIcon = item.icon;
            return (
              <Card
                as="article"
                tone="muted"
                size="sm"
                class="flex h-full min-h-0 flex-col transition-colors hover:border-[var(--color-nav-active-border)] hover:bg-[var(--color-brand-soft)]"
              >
                <div class="flex min-h-0 flex-1 flex-col gap-3">
                  <div class="flex min-h-0 flex-1 items-stretch gap-3">
                    <span class={homeIconBox}>
                      <ResIcon class="size-[1.125rem] shrink-0 stroke-[currentColor]" aria-hidden="true" />
                    </span>
                    <div class="flex min-h-0 flex-1 flex-col">
                      <h3 class="text-base font-semibold leading-[var(--leading-title)] text-[var(--color-text)]">
                        <a href={item.href} class="transition-colors hover:text-[var(--color-brand-text)]">
                          {item.title}
                        </a>
                      </h3>
                      <p class="mt-2 flex-1 text-sm leading-[var(--leading-body)] text-[var(--color-text-muted)]">
                        {item.description}
                      </p>
                      <a
                        href={item.href}
                        class="mt-auto inline-flex items-center gap-1.5 pt-4 text-sm font-semibold text-[var(--color-brand-text)] transition-colors hover:text-[var(--color-brand-hover)]"
                      >
                        Read more
                        <ArrowRight class="size-4 shrink-0 stroke-[currentColor]" aria-hidden="true" />
                      </a>
                    </div>
                  </div>
                </div>
              </Card>
            );
          })
        }
      </div>

      <a
        href="/guides"
        class="mt-4 inline-flex text-sm font-semibold text-[var(--color-brand-text)] transition-colors hover:text-[var(--color-brand-hover)] sm:hidden"
      >
        View resources →
      </a>
    </section>

    <section
      class="rounded-[var(--radius-2xl)] border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-[var(--shadow-xs)] sm:p-8"
      aria-labelledby="safety-heading"
    >
      <div class="max-w-3xl">
        <h2
          id="safety-heading"
          class="text-2xl font-semibold tracking-[var(--tracking-heading)] text-[var(--color-text)]"
        >
          Built for non-custodial workflows
        </h2>

        <p class="mt-4 text-sm leading-[var(--leading-body)] text-[var(--color-text-secondary)]">
          Solana Tools does not take custody of your assets. Public pages explain each workflow before any wallet
          action is needed. When a transaction is required, the transaction is prepared first and the connected wallet
          signs only after the user confirms the action.
        </p>

        <p class="mt-4 text-sm leading-[var(--leading-body)] text-[var(--color-text-muted)]">
          Always verify the selected network, token address, authority settings, and estimated fees before signing.
        </p>
      </div>
    </section>

    <section
      class="flex flex-col gap-6 rounded-[var(--radius-2xl)] border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-[var(--shadow-xs)] sm:flex-row sm:items-center sm:justify-between sm:gap-8 sm:p-8"
      aria-labelledby="cta-strip-heading"
    >
      <div class="min-w-0 flex-1">
        <h2
          id="cta-strip-heading"
          class="text-xl font-semibold tracking-[var(--tracking-heading)] text-[var(--color-text)] sm:text-2xl"
        >
          Ready to work on-chain?
        </h2>
        <p class="mt-2 max-w-xl text-sm leading-[var(--leading-body)] text-[var(--color-text-secondary)]">
          Start with token creation, then explore management and authority tools at your own pace.
        </p>
      </div>
      <div class="flex w-full shrink-0 flex-col gap-3 sm:w-auto sm:flex-row sm:items-stretch sm:justify-end sm:gap-3">
        <Button
          href="/create-solana-token"
          variant="primary"
          size="lg"
          class="w-full min-h-[var(--control-lg)] justify-center sm:w-auto"
        >
          Create a token
        </Button>
        <Button
          href="/safety"
          variant="outline"
          size="lg"
          class="w-full min-h-[var(--control-lg)] justify-center sm:w-auto"
        >
          Review safety
        </Button>
      </div>
    </section>
  </div>

  <style>
    .hero-art {
      background-color: transparent;
      background-image: url("/images/hero-solana-light.webp");
      background-image: image-set(
        url("/images/hero-solana-light.avif") type("image/avif"),
        url("/images/hero-solana-light.webp") type("image/webp")
      );
      background-repeat: no-repeat;
      background-position: center;
      background-size: contain;
    }

    /* Light theme: slightly stronger artwork presence (decorative only; no extra image requests). */
    :global(html:not(.dark)) .hero-art {
      filter: saturate(1.22) contrast(1.09);
      background-size: min(108%, 40rem);
    }

    :global(.dark) .hero-art {
      background-image: url("/images/hero-solana-dark.webp");
      background-image: image-set(
        url("/images/hero-solana-dark.avif") type("image/avif"),
        url("/images/hero-solana-dark.webp") type("image/webp")
      );
    }
  </style>
</BaseLayout>
