---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Solana Tools" description="Modern and responsive Solana tools interface.">
	<section
		class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-sm hover:border-[var(--color-nav-active-border)]"
	>
		<h1 class="text-2xl font-semibold tracking-tight text-[var(--color-text)]">Modern layout shell in progress</h1>
		<p class="mt-3 max-w-2xl text-sm leading-7 text-[var(--color-text-muted)]">
			The responsive header, desktop sidebar, and footer are now in place with a mobile-friendly navigation flow.
		</p>
	</section>
</BaseLayout>
