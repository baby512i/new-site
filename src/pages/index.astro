---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Solana Tools" description="Modern and responsive Solana tools interface.">
	<section
		class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm hover:border-blue-300 dark:border-slate-800 dark:bg-slate-900 dark:hover:border-sky-700"
	>
		<h1 class="text-2xl font-semibold tracking-tight text-slate-950 dark:text-slate-50">Modern layout shell in progress</h1>
		<p class="mt-3 max-w-2xl text-sm leading-7 text-slate-600 dark:text-slate-300">
			The responsive header, desktop sidebar, and footer are now in place with a mobile-friendly navigation flow.
		</p>
	</section>
</BaseLayout>
