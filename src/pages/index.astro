---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Solana Tools" description="Modern and responsive Solana tools interface.">
	<section class="rounded-xl border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-900">
		<h1 class="text-2xl font-semibold">Modern layout shell in progress</h1>
		<p class="mt-3 max-w-2xl text-sm text-slate-600 dark:text-slate-300">
			The responsive header, desktop sidebar, and footer are now in place with a mobile-friendly navigation flow.
		</p>
	</section>
</BaseLayout>
