---
import BaseLayout from "../layouts/BaseLayout.astro";
import CreateTokenLanding from "../components/tools/create-token/CreateTokenLanding.astro";
import { CREATE_TOKEN_PLATFORMS } from "../lib/tool-config/create-token-platforms";

const platform = CREATE_TOKEN_PLATFORMS.raydiumLaunchlab;
const canonical = new URL(
  platform.url,
  Astro.site ?? "https://yourdomain.com",
).toString();
---

<BaseLayout
  title={platform.title}
  description={platform.metaDescription}
  canonical={canonical}
>
  <CreateTokenLanding platformId="raydiumLaunchlab" />
</BaseLayout>
